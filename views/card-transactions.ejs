<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Transacoes do Cartao - RC2 Finance</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans text-slate-900">
  <div class="container mx-auto px-4 sm:px-6 py-6 max-w-6xl">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
      <div>
        <a href="/credit-cards" class="text-sm text-[#00C9A7] hover:text-[#00b295] font-medium">Voltar para cartoes</a>
        <h1 class="text-2xl sm:text-3xl font-semibold text-slate-900 mt-1"><%= card.name %></h1>
      </div>
      <a href="/credit-cards/<%= card.id %>/add-transaction" class="min-h-[44px] inline-flex items-center bg-[#00C9A7] hover:bg-[#00b295] text-white font-medium py-2 px-4 rounded-lg transition-colors">
        + Novo gasto
      </a>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 mb-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
          <p class="text-xs text-slate-500 mb-1">Limite total</p>
          <p class="text-xl font-semibold text-slate-900"><%= formatCurrency(card.limit_amount) %></p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
          <p class="text-xs text-slate-500 mb-1">Gasto no mes</p>
          <p class="text-xl font-semibold text-rose-600"><%= formatCurrency(totalThisMonth) %></p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
          <p class="text-xs text-slate-500 mb-1">Disponivel</p>
          <p class="text-xl font-semibold <%= availableLimit < 0 ? 'text-rose-600' : 'text-emerald-600' %>"><%= formatCurrency(availableLimit) %></p>
        </div>
      </div>
    </div>

    <% if (error) { %>
      <div class="mb-6 rounded-xl border border-rose-200 bg-rose-50 text-rose-700 px-4 py-3"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-700 px-4 py-3"><%= success %></div>
    <% } %>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200">
      <% if (transactions.length === 0) { %>
        <div class="text-center py-14 px-6">
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Nenhuma transacao</h3>
          <p class="text-slate-600">Adicione o primeiro gasto deste cartao.</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full min-w-[720px]">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50">
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">Descricao</th>
                <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-600">Valor</th>
                <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wide text-slate-600">Data</th>
                <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wide text-slate-600">Acoes</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach(transaction => { %>
                <tr class="border-b border-slate-100 last:border-b-0 hover:bg-slate-50 transition-colors">
                  <td class="px-5 py-4 text-sm font-medium text-slate-800"><%= transaction.description %></td>
                  <td class="px-5 py-4 text-right text-sm font-semibold text-rose-600"><%= formatCurrency(transaction.amount) %></td>
                  <td class="px-5 py-4 text-center text-sm text-slate-600"><%= formatDate(transaction.date) %></td>
                  <td class="px-5 py-4 text-center">
                    <div class="inline-flex items-center gap-3">
                      <a href="/credit-cards/<%= card.id %>/edit-transaction/<%= transaction.id %>" class="text-sm font-medium text-blue-600 hover:text-blue-700">Editar</a>
                      <form action="/credit-cards/<%= card.id %>/delete-transaction/<%= transaction.id %>" method="POST" class="inline" onsubmit="return confirm('Tem certeza que deseja excluir esta transacao?');">
                        <button type="submit" class="text-sm font-medium text-rose-600 hover:text-rose-700">Excluir</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
