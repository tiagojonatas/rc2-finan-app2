<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Categorias - Sistema Financeiro</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 font-sans">
  <div class="container mx-auto px-6 py-6 max-w-5xl">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Categorias</h1>
      <div class="flex gap-3">
        <a href="/dashboard" class="bg-white border border-gray-300 text-gray-700 py-2 px-4 rounded-xl hover:bg-gray-50">Dashboard</a>
        <a href="/categories/add" class="bg-[#8A05BE] hover:bg-[#6A047E] text-white py-2 px-4 rounded-xl">+ Nova categoria</a>
      </div>
    </div>

    <% if (error) { %>
      <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 text-rose-700 px-4 py-3"><%= error %></div>
    <% } %>

    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
      <div class="grid grid-cols-12 px-5 py-3 bg-slate-50 border-b border-gray-200 text-xs font-semibold uppercase tracking-wide text-gray-600">
        <div class="col-span-5">Nome</div>
        <div class="col-span-3">Tipo</div>
        <div class="col-span-2 text-center">Cor</div>
        <div class="col-span-2 text-right">Acoes</div>
      </div>
      <% if (!categories || categories.length === 0) { %>
        <div class="p-8 text-center text-gray-500">Nenhuma categoria cadastrada</div>
      <% } %>
      <% categories.forEach((category, index) => { %>
        <div class="grid grid-cols-12 items-center px-5 py-4 <%= index < categories.length - 1 ? 'border-b border-gray-100' : '' %>">
          <div class="col-span-5 font-semibold text-gray-900"><%= category.name %></div>
          <div class="col-span-3">
            <span class="inline-flex px-2 py-1 rounded-full text-xs font-semibold <%= category.type === 'income' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
              <%= category.type === 'income' ? 'Entrada' : 'Despesa' %>
            </span>
          </div>
          <div class="col-span-2 flex justify-center">
            <span class="inline-flex items-center gap-2 text-xs font-semibold text-gray-700">
              <span class="w-4 h-4 rounded-full border border-white shadow-sm" style="background-color: <%= category.color %>;"></span>
              <%= category.color %>
            </span>
          </div>
          <div class="col-span-2 flex justify-end">
            <form action="/categories/delete/<%= category.id %>" method="POST" onsubmit="return confirm('Excluir categoria?');">
              <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-rose-50 hover:bg-rose-100 text-rose-700">Excluir</button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</body>
</html>
