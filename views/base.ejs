<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : (typeof pageTitle !== 'undefined' ? pageTitle : 'RC2 Finance') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <% if (typeof includeChartJs !== 'undefined' && includeChartJs) { %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <% } %>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif']
          },
          colors: {
            brand: {
              500: '#00C9A7',
              600: '#009e83'
            },
            'brand-purple': '#00C9A7',
            'brand-cyan-light': '#3A86FF',
            'brand-cyan-dark': '#009e83',
            'brand-cyan-50': '#ecfeff',
            'brand-cyan-100': '#cffafe',
            'brand-cyan-200': '#a5f3fc'
          }
        }
      }
    };
  </script>
  <style>
    body {
      background: linear-gradient(to bottom right, #020617, #0f172a, #020617);
      min-height: 100vh;
    }
    .glass-card {
      background: #111827;
      color: #ffffff;
      border: 1px solid #1f2937;
      border-radius: 0.75rem;
      padding: 1.5rem;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.28);
    }
    .glass-card:hover {
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.34);
    }
    .toast-enter {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
    .toast-show {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    .tx-highlight {
      animation: txPulse 1.1s ease-out;
    }
    @keyframes txPulse {
      0% { background-color: rgba(0, 201, 167, 0.18); }
      100% { background-color: transparent; }
    }
  </style>
</head>
<body class="bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 font-sans text-gray-200 overflow-x-hidden">
  <% const activePath = typeof currentPath !== 'undefined' ? currentPath : ''; %>
  <% const hasHeader = !(typeof hideHeader !== 'undefined' && hideHeader); %>
  <% const userDisplayName = user && (user.name || user.nome) ? (user.name || user.nome) : ''; %>
  <% const userInitial = userDisplayName ? userDisplayName.charAt(0).toUpperCase() : 'U'; %>
  <% const navClass = (path) => activePath === path
    ? 'bg-brand-500/20 text-brand-500 border border-brand-500/40'
    : 'bg-gray-900 text-gray-300 border border-gray-700 hover:bg-gray-800'; %>

  <% if (hasHeader) { %>
    <header class="bg-slate-900/80 backdrop-blur border-b border-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-2.5 sm:py-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <img src="/brand/rc2-finance-horizontal.svg" alt="RC2 Finance" class="h-8 sm:h-10 w-auto" />
          <p class="text-xs text-emerald-400 font-semibold tracking-wide hidden sm:block">by RC2 Tecnologia</p>
        </div>
        <nav class="hidden md:flex items-center gap-2">
          <a href="/dashboard" class="h-12 inline-flex items-center rounded-lg px-4 py-3 text-sm transition-all duration-200 <%= navClass('/dashboard') %>">Visao Geral</a>
          <a href="/analysis" class="h-12 inline-flex items-center rounded-lg px-4 py-3 text-sm transition-all duration-200 <%= navClass('/analysis') %>">Analise de gastos</a>
          <a href="/credit-cards" class="h-12 inline-flex items-center rounded-lg px-4 py-3 text-sm transition-all duration-200 <%= navClass('/credit-cards') %>">Cartoes</a>
          <a href="/reports" class="h-12 inline-flex items-center rounded-lg px-4 py-3 text-sm transition-all duration-200 <%= navClass('/reports') %>">Relatorios</a>
          <a href="/categories" class="h-12 inline-flex items-center rounded-lg px-4 py-3 text-sm transition-all duration-200 <%= navClass('/categories') %>">Categorias</a>
        </nav>
        <div class="hidden md:flex items-center gap-3 sm:gap-4">
          <% if (userDisplayName) { %>
            <div class="hidden sm:flex items-center gap-3 text-sm text-slate-300">
              <div class="text-slate-400"><%= currentDate %></div>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-emerald-500/90 text-white font-semibold flex items-center justify-center">
                  <%= userInitial %>
                </div>
                <span class="text-white font-medium"><%= userDisplayName %></span>
              </div>
            </div>
          <% } %>
          <form action="/logout" method="POST">
            <button type="submit" class="h-12 inline-flex items-center rounded-lg px-4 py-3 text-sm bg-gray-900 text-gray-300 border border-gray-700 hover:bg-gray-800 transition-all duration-200">
              Sair
            </button>
          </form>
        </div>
        <div class="flex md:hidden items-center gap-2">
          <% if (userDisplayName) { %>
            <div class="w-8 h-8 rounded-full bg-emerald-500/90 text-white text-xs font-semibold flex items-center justify-center">
              <%= userInitial %>
            </div>
          <% } %>
          <button id="mobileMenuButton" type="button" class="h-12 w-12 inline-flex items-center justify-center rounded-lg border border-slate-700 bg-gray-900 text-gray-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div id="mobileMenu" class="fixed inset-0 z-[85] hidden md:hidden">
      <div id="mobileMenuBackdrop" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-200"></div>
      <aside id="mobileMenuPanel" class="absolute right-0 top-0 h-full w-72 max-w-[86vw] bg-slate-900 border-l border-slate-800 p-4 space-y-4 translate-x-full transition-transform duration-200">
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold text-white">Menu</p>
          <button id="mobileMenuClose" type="button" class="h-10 w-10 inline-flex items-center justify-center rounded-lg border border-slate-700 bg-slate-800 text-slate-300">X</button>
        </div>
        <% if (userDisplayName) { %>
          <div class="rounded-lg border border-slate-700 bg-slate-800/70 p-3">
            <p class="text-xs text-slate-400"><%= currentDate %></p>
            <p class="text-sm font-medium text-white mt-1"><%= userDisplayName %></p>
          </div>
        <% } %>
        <nav class="flex flex-col gap-3">
          <a href="/dashboard" class="h-12 px-4 py-3 rounded-lg inline-flex items-center <%= navClass('/dashboard') %>">Visao Geral</a>
          <a href="/analysis" class="h-12 px-4 py-3 rounded-lg inline-flex items-center <%= navClass('/analysis') %>">Analise de gastos</a>
          <a href="/credit-cards" class="h-12 px-4 py-3 rounded-lg inline-flex items-center <%= navClass('/credit-cards') %>">Cartoes</a>
          <a href="/reports" class="h-12 px-4 py-3 rounded-lg inline-flex items-center <%= navClass('/reports') %>">Relatorios</a>
          <a href="/categories" class="h-12 px-4 py-3 rounded-lg inline-flex items-center <%= navClass('/categories') %>">Categorias</a>
        </nav>
        <form action="/logout" method="POST">
          <button type="submit" class="w-full h-12 px-4 py-3 rounded-lg border border-slate-700 bg-gray-900 text-gray-300 hover:bg-gray-800 transition-all duration-200">
            Sair
          </button>
        </form>
      </aside>
    </div>
  <% } %>

  <% const contentPath = typeof content !== 'undefined' ? content : contentPartial; %>
  <main class="max-w-6xl mx-auto px-4 sm:px-5 py-5 sm:py-6 <%= typeof mainClass !== 'undefined' ? mainClass : 'space-y-6' %>">
    <%- include(contentPath) %>
  </main>

  <div id="confirmModal" class="fixed inset-0 z-[90] hidden items-center justify-center p-4">
    <div id="confirmBackdrop" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-200"></div>
    <div id="confirmPanel" class="relative w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-5 shadow-2xl opacity-0 scale-95 transition-all duration-200">
      <h3 id="confirmTitle" class="text-lg font-semibold text-white tracking-tight">Confirmar acao</h3>
      <p id="confirmMessage" class="mt-2 text-sm text-slate-300">Tem certeza que deseja continuar?</p>
      <div class="mt-5 flex items-center justify-end gap-2">
        <button id="confirmCancel" type="button" class="min-h-[40px] px-4 py-2 rounded-lg border border-slate-700 bg-slate-800 text-slate-300 hover:bg-slate-700 transition-all duration-200">
          Cancelar
        </button>
        <button id="confirmSubmit" type="button" class="min-h-[40px] px-4 py-2 rounded-lg bg-rose-500 text-white hover:bg-rose-600 transition-all duration-200">
          Excluir
        </button>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const confirmModal = document.getElementById('confirmModal');
      const confirmBackdrop = document.getElementById('confirmBackdrop');
      const confirmPanel = document.getElementById('confirmPanel');
      const confirmTitle = document.getElementById('confirmTitle');
      const confirmMessage = document.getElementById('confirmMessage');
      const confirmCancel = document.getElementById('confirmCancel');
      const confirmSubmit = document.getElementById('confirmSubmit');
      const mobileMenu = document.getElementById('mobileMenu');
      const mobileMenuBackdrop = document.getElementById('mobileMenuBackdrop');
      const mobileMenuPanel = document.getElementById('mobileMenuPanel');
      const mobileMenuButton = document.getElementById('mobileMenuButton');
      const mobileMenuClose = document.getElementById('mobileMenuClose');
      let pendingForm = null;
      let isConfirmOpen = false;
      let isMobileMenuOpen = false;

      function setConfirmState(open) {
        isConfirmOpen = open;
        if (!confirmModal || !confirmBackdrop || !confirmPanel) return;

        if (open) {
          confirmModal.classList.remove('hidden');
          confirmModal.classList.add('flex');
          requestAnimationFrame(function() {
            confirmBackdrop.classList.remove('opacity-0');
            confirmBackdrop.classList.add('opacity-100');
            confirmPanel.classList.remove('opacity-0', 'scale-95');
            confirmPanel.classList.add('opacity-100', 'scale-100');
          });
        } else {
          confirmBackdrop.classList.add('opacity-0');
          confirmBackdrop.classList.remove('opacity-100');
          confirmPanel.classList.add('opacity-0', 'scale-95');
          confirmPanel.classList.remove('opacity-100', 'scale-100');
          setTimeout(function() {
            if (!isConfirmOpen) {
              confirmModal.classList.add('hidden');
              confirmModal.classList.remove('flex');
            }
          }, 200);
        }
      }

      function openConfirmFor(form) {
        pendingForm = form;
        if (confirmTitle) {
          confirmTitle.textContent = form.getAttribute('data-confirm-title') || 'Confirmar acao';
        }
        if (confirmMessage) {
          confirmMessage.textContent = form.getAttribute('data-confirm-message') || 'Tem certeza que deseja continuar?';
        }
        setConfirmState(true);
      }

      function closeConfirm() {
        setConfirmState(false);
        pendingForm = null;
      }

      function setMobileMenuState(open) {
        if (!mobileMenu || !mobileMenuBackdrop || !mobileMenuPanel) return;
        isMobileMenuOpen = open;
        if (open) {
          mobileMenu.classList.remove('hidden');
          requestAnimationFrame(function() {
            mobileMenuBackdrop.classList.remove('opacity-0');
            mobileMenuBackdrop.classList.add('opacity-100');
            mobileMenuPanel.classList.remove('translate-x-full');
          });
        } else {
          mobileMenuBackdrop.classList.add('opacity-0');
          mobileMenuBackdrop.classList.remove('opacity-100');
          mobileMenuPanel.classList.add('translate-x-full');
          setTimeout(function() {
            if (!isMobileMenuOpen) {
              mobileMenu.classList.add('hidden');
            }
          }, 200);
        }
      }

      document.querySelectorAll('form[data-confirm-message]').forEach(function(form) {
        form.addEventListener('submit', function(event) {
          event.preventDefault();
          openConfirmFor(form);
        });
      });

      if (confirmCancel) {
        confirmCancel.addEventListener('click', closeConfirm);
      }
      if (confirmBackdrop) {
        confirmBackdrop.addEventListener('click', closeConfirm);
      }
      if (confirmSubmit) {
        confirmSubmit.addEventListener('click', function() {
          if (pendingForm) {
            const targetForm = pendingForm;
            pendingForm = null;
            setConfirmState(false);
            targetForm.submit();
          } else {
            closeConfirm();
          }
        });
      }
      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && isConfirmOpen) {
          closeConfirm();
        }
        if (event.key === 'Escape' && isMobileMenuOpen) {
          setMobileMenuState(false);
        }
      });

      if (mobileMenuButton) {
        mobileMenuButton.addEventListener('click', function() {
          setMobileMenuState(true);
        });
      }
      if (mobileMenuClose) {
        mobileMenuClose.addEventListener('click', function() {
          setMobileMenuState(false);
        });
      }
      if (mobileMenuBackdrop) {
        mobileMenuBackdrop.addEventListener('click', function() {
          setMobileMenuState(false);
        });
      }
      if (mobileMenuPanel) {
        mobileMenuPanel.querySelectorAll('a').forEach(function(link) {
          link.addEventListener('click', function() {
            setMobileMenuState(false);
          });
        });
      }
    });
  </script>
</body>
</html>
