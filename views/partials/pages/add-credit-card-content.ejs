<div class="max-w-xl mx-auto mt-10">
  <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-white mb-6">Novo Cartao</h2>

    <% if (error) { %>
      <div class="mb-4 text-red-400 text-sm"><%= error %></div>
    <% } %>

    <form action="/credit-cards/add" method="POST" class="space-y-4">
      <div>
        <label for="name" class="text-sm text-slate-400">Nome do Cartao</label>
        <input id="name" name="name" type="text" placeholder="Ex: Cartao Principal" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
      </div>
      <div>
        <label for="limit_amount" class="text-sm text-slate-400">Limite (R$)</label>
        <input id="limitDisplay" type="text" inputmode="numeric" placeholder="0,00" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
        <input id="limit_amount" name="limit_amount" type="hidden" value="0.00">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="closing_day" class="text-sm text-slate-400">Dia Fechamento</label>
          <input id="closing_day" name="closing_day" type="number" min="1" max="31" placeholder="5" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
        </div>
        <div>
          <label for="due_day" class="text-sm text-slate-400">Dia Vencimento</label>
          <input id="due_day" name="due_day" type="number" min="1" max="31" placeholder="15" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500">
        </div>
      </div>

      <div class="flex gap-2 pt-4">
        <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white px-4 py-2 rounded-lg">Salvar</button>
        <a href="/credit-cards" class="px-4 py-2 border border-slate-700 rounded-lg text-slate-300">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
  const limitDisplay = document.getElementById('limitDisplay');
  const limitInput = document.getElementById('limit_amount');

  function formatBRL(value) {
    return value.toLocaleString('pt-BR', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });
  }

  limitDisplay.addEventListener('input', function(event) {
    let value = event.target.value.replace(/\D/g, '');

    if (value === '') {
      limitDisplay.value = '';
      limitInput.value = '0.00';
      return;
    }

    const numValue = parseInt(value, 10) / 100;
    const formatted = formatBRL(numValue);

    limitDisplay.value = formatted;
    limitInput.value = numValue.toFixed(2);
  });

  limitDisplay.addEventListener('keypress', function(event) {
    const char = String.fromCharCode(event.which);
    if (!/[0-9]/.test(char)) {
      event.preventDefault();
    }
  });

  limitDisplay.addEventListener('paste', function(event) {
    event.preventDefault();
    const pastedText = (event.clipboardData || window.clipboardData).getData('text');
    const numericOnly = pastedText.replace(/\D/g, '');

    if (numericOnly) {
      limitDisplay.value = numericOnly;
      limitDisplay.dispatchEvent(new Event('input'));
    }
  });
</script>
