<div class="bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 relative pb-20 space-y-8 rounded-2xl">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.08),transparent_60%)] pointer-events-none"></div>

  <div class="relative z-10 flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4 mb-8">
    <div>
      <h1 class="text-xl sm:text-2xl font-semibold text-white tracking-tight">Analise de gastos</h1>
      <p id="currentMonth" class="text-slate-400 text-sm mt-1.5 sm:mt-2"></p>
      <p class="text-xs text-slate-500 mt-2">Transacoes que nao impactam o saldo real</p>
      <% if (typeof isFutureMonth !== 'undefined' && isFutureMonth) { %>
        <span class="mt-2 inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold border border-cyan-700 bg-cyan-900/30 text-cyan-300">
          Mes futuro (projetado)
        </span>
      <% } %>
    </div>

    <div class="w-full sm:w-auto flex flex-col sm:flex-row sm:flex-wrap items-stretch sm:items-center sm:justify-end gap-3">
      <form id="monthFilterForm" action="/analysis" method="GET" class="w-full sm:w-auto bg-[#111827] text-gray-300 border border-gray-700 hover:bg-gray-800 rounded-lg px-4 py-3 h-12 flex items-center gap-2 transition-all duration-200">
        <label for="monthFilter" class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Periodo</label>
        <select id="monthFilter" name="month" class="bg-transparent text-sm font-semibold text-white focus:outline-none w-full sm:w-auto">
          <% const safeMonthOptions = Array.isArray(monthOptions) ? monthOptions : []; %>
          <% safeMonthOptions.forEach((monthKey) => { %>
            <% const [year, month] = monthKey.split('-').map(Number); %>
            <% const monthLabel = new Date(year, month - 1, 1).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }); %>
            <option value="<%= monthKey %>" <%= monthKey === selectedMonth ? 'selected' : '' %>><%= monthLabel %></option>
          <% }); %>
        </select>
      </form>
      <a href="/dashboard" class="w-full sm:w-auto bg-[#111827] text-gray-300 border border-gray-700 hover:bg-gray-800 rounded-lg px-4 py-3 h-12 inline-flex items-center justify-center transition-all duration-200">
        Voltar ao dashboard
      </a>
    </div>
  </div>

  <% const summary = analysisSummary || {}; %>
  <% const safeGroups = Array.isArray(analysisTransactionGroups) ? analysisTransactionGroups : []; %>
  <% const safeCategoryReport = Array.isArray(analysisCategoryReport) ? analysisCategoryReport : []; %>
  <% const totalAnalyzed = Number(summary.totalAnalysisExpenses || 0); %>
  <% const invoiceValue = Number(summary.creditInvoiceTotal || 0); %>
  <% const analysisDiff = totalAnalyzed - invoiceValue; %>
  <% const topCategory = safeCategoryReport.length > 0 ? safeCategoryReport[0] : null; %>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
      <p class="text-slate-400 text-xs uppercase tracking-wide mb-1">Total analisado (cartao)</p>
      <p class="text-xl font-semibold text-rose-300"><%= formatCurrency(totalAnalyzed) %></p>
    </div>
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
      <p class="text-slate-400 text-xs uppercase tracking-wide mb-1">Resumo dos gastos analisados</p>
      <p class="text-xl font-semibold text-sky-300"><%= formatCurrency(invoiceValue) %></p>
    </div>
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
      <p class="text-slate-400 text-xs uppercase tracking-wide mb-1">Debito</p>
      <p class="text-xl font-semibold text-cyan-300"><%= formatCurrency(summary.debitTotal || 0) %></p>
    </div>
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
      <p class="text-slate-400 text-xs uppercase tracking-wide mb-1">Dinheiro</p>
      <p class="text-xl font-semibold text-amber-300"><%= formatCurrency(summary.cashTotal || 0) %></p>
    </div>
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
      <p class="text-slate-400 text-xs uppercase tracking-wide mb-1">Lancamentos</p>
      <p class="text-xl font-semibold text-slate-200"><%= Number(summary.transactionsCount || 0) %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
      <p class="text-slate-400 text-xs uppercase tracking-wide mb-1">Comparacao do periodo</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-2">
        <div class="rounded-lg border border-slate-800 bg-[#111827] p-3">
          <p class="text-[11px] uppercase tracking-wide text-slate-400 mb-1">Valor da fatura</p>
          <p class="text-sm font-semibold text-sky-300"><%= formatCurrency(invoiceValue) %></p>
        </div>
        <div class="rounded-lg border border-slate-800 bg-[#111827] p-3">
          <p class="text-[11px] uppercase tracking-wide text-slate-400 mb-1">Total analisado</p>
          <p class="text-sm font-semibold text-rose-300"><%= formatCurrency(totalAnalyzed) %></p>
        </div>
        <div class="rounded-lg border border-slate-800 bg-[#111827] p-3">
          <p class="text-[11px] uppercase tracking-wide text-slate-400 mb-1">Diferenca</p>
          <p class="text-sm font-semibold <%= analysisDiff >= 0 ? 'text-amber-300' : 'text-emerald-300' %>">
            <%= formatCurrency(Math.abs(analysisDiff)) %>
          </p>
        </div>
      </div>
    </div>
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
      <p class="text-slate-400 text-xs uppercase tracking-wide mb-1">Maior gasto</p>
      <% if (topCategory) { %>
        <p class="text-base font-semibold text-white">
          <%= topCategory.name %> (<%= (topCategory.percentage || 0).toFixed(1) %>%)
        </p>
        <p class="text-sm text-slate-400 mt-1">Categoria com maior peso no consumo analisado.</p>
      <% } else { %>
        <p class="text-sm text-slate-400">Sem gastos analisados no periodo para identificar destaque.</p>
      <% } %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="rounded-xl border border-gray-800 p-4 bg-[#0f172a] min-h-[260px] flex items-center justify-center">
      <% if (safeCategoryReport.length > 0) { %>
        <canvas id="analysisCategoryChart" class="max-h-[280px]"></canvas>
      <% } else { %>
        <div class="text-center max-w-md">
          <p class="text-sm text-slate-300 font-medium">Sem categorias para exibir no periodo.</p>
          <p class="text-xs text-slate-500 mt-2">
            Para usar esta area, cadastre despesas e desmarque "Impacta saldo" no formulario de transacao.
          </p>
        </div>
      <% } %>
    </div>
    <div class="rounded-xl border border-gray-800 p-4 bg-[#0f172a]">
      <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-3">Categorias de gastos</h3>
      <% if (safeCategoryReport.length === 0) { %>
        <p class="text-sm text-slate-400">Nenhuma despesa de analise encontrada.</p>
      <% } else { %>
        <div class="space-y-2">
          <% safeCategoryReport.slice(0, 8).forEach((item, idx) => { %>
            <div class="flex items-center justify-between rounded-lg border border-gray-800 px-3 py-2 bg-[#111827]">
              <div class="flex items-center gap-2 min-w-0">
                <span class="text-xs text-gray-500 w-5"><%= idx + 1 %></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= item.color || '#00C9A7' %>;"></span>
                <p class="text-sm text-gray-200 truncate"><%= item.name %></p>
              </div>
              <div class="text-right ml-2">
                <p class="text-sm font-semibold text-white"><%= formatCurrency(item.total || 0) %></p>
                <p class="text-xs text-slate-400"><%= (item.percentage || 0).toFixed(1) %>%</p>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>

  <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
    <h2 class="text-xl font-semibold tracking-tight text-white mb-4">Despesas detalhadas</h2>
    <% if (safeGroups.length === 0) { %>
      <div class="rounded-xl border border-dashed border-slate-700 p-8 text-center">
        <p class="text-slate-300 font-medium">Nenhum lancamento de analise encontrado neste periodo.</p>
        <p class="text-slate-500 text-sm mt-2">
          Dica: ao cadastrar uma despesa de acompanhamento (ex: compras no cartao), desmarque "Impacta saldo" para ela aparecer aqui.
        </p>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% safeGroups.forEach((group) => { %>
          <div class="rounded-xl border border-slate-800 bg-[#0f172a] overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-800 flex items-center justify-between">
              <p class="text-sm font-semibold text-white"><%= group.dateLabel %></p>
              <p class="text-sm font-semibold text-rose-300"><%= formatCurrency(group.total || 0) %></p>
            </div>

            <% group.transactions.forEach((transaction, index) => { %>
              <% const isInstallment = Number(transaction && transaction.installment_total || 1) > 1; %>
              <div class="px-4 py-4 <%= index < group.transactions.length - 1 ? 'border-b border-slate-800' : '' %>">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-white truncate">
                      <%= transaction && transaction.description ? transaction.description : 'Sem descricao' %>
                    </p>
                    <div class="mt-2 flex flex-wrap items-center gap-2">
                      <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[11px] font-semibold text-gray-300 bg-[#111827] border border-gray-800">
                        <span class="w-2 h-2 rounded-full" style="background-color: <%= transaction && transaction.category_color ? transaction.category_color : '#00C9A7' %>;"></span>
                        <%= transaction && transaction.category_name ? transaction.category_name : 'Sem categoria' %>
                      </span>
                      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold border <%= transaction && transaction.payment_method === 'credit' ? 'bg-sky-900/40 text-sky-300 border-sky-700' : transaction && transaction.payment_method === 'debit' ? 'bg-cyan-900/40 text-cyan-300 border-cyan-700' : 'bg-amber-900/40 text-amber-300 border-amber-700' %>">
                        <%= transaction && transaction.payment_method === 'credit' ? 'Credito' : transaction && transaction.payment_method === 'debit' ? 'Debito' : 'Dinheiro' %>
                      </span>
                      <% if (isInstallment) { %>
                        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold bg-violet-900/40 text-violet-300 border border-violet-700">
                          Parcelado
                        </span>
                      <% } %>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="text-base font-semibold text-rose-300"><%= formatCurrency(transaction.amount || 0) %></p>
                    <p class="text-xs text-slate-400"><%= transaction && transaction.date ? formatDate(transaction.date) : '' %></p>
                    <div class="mt-2 flex items-center justify-end gap-2">
                      <a href="/transactions/edit/<%= transaction && transaction.id ? transaction.id : '' %>"
                        class="text-xs px-3 py-1.5 rounded-lg bg-gray-950 hover:bg-gray-800 text-gray-300 border border-gray-700">Editar</a>
                      <form action="/transactions/delete/<%= transaction && transaction.id ? transaction.id : '' %>" method="POST" class="inline"
                        data-confirm-title="<%= isInstallment ? 'Excluir parcela' : 'Excluir transacao' %>"
                        data-confirm-message="<%= isInstallment ? 'Tem certeza que deseja excluir apenas esta parcela?' : 'Tem certeza que deseja excluir esta transacao?' %>">
                        <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-gray-950 hover:bg-gray-800 text-gray-300 border border-gray-700">
                          <%= isInstallment ? 'Excluir parcela' : 'Excluir' %>
                        </button>
                      </form>
                      <% if (isInstallment) { %>
                        <form action="/transactions/delete/<%= transaction && transaction.id ? transaction.id : '' %>" method="POST" class="inline"
                          data-confirm-title="Excluir compra parcelada"
                          data-confirm-message="Tem certeza que deseja excluir todas as parcelas desta compra?">
                          <input type="hidden" name="delete_scope" value="group" />
                          <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-rose-900/30 hover:bg-rose-900/50 text-rose-300 border border-rose-800">
                            Excluir compra
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const currentMonthElement = document.getElementById('currentMonth');
      const selectedMonthLabel = <%- JSON.stringify(typeof selectedMonthLabel !== 'undefined' ? selectedMonthLabel : '') %>;
      if (currentMonthElement) {
        currentMonthElement.textContent = selectedMonthLabel || '';
      }

      const monthFilter = document.getElementById('monthFilter');
      const monthFilterForm = document.getElementById('monthFilterForm');
      if (monthFilter && monthFilterForm) {
        monthFilter.addEventListener('change', function() {
          monthFilterForm.submit();
        });
      }

      const chartEl = document.getElementById('analysisCategoryChart');
      if (chartEl && typeof Chart !== 'undefined') {
        const chartData = <%- JSON.stringify((Array.isArray(analysisCategoryReport) ? analysisCategoryReport : []).map((item) => ({
          name: item.name,
          total: Number(item.total || 0),
          color: item.color || '#00C9A7'
        }))) %>;

        if (chartData.length > 0) {
          new Chart(chartEl, {
            type: 'doughnut',
            data: {
              labels: chartData.map((item) => item.name),
              datasets: [{
                data: chartData.map((item) => item.total),
                backgroundColor: chartData.map((item) => item.color),
                borderColor: '#111827',
                borderWidth: 2
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: {
                    color: '#d1d5db',
                    boxWidth: 12,
                    padding: 12
                  }
                },
                tooltip: {
                  callbacks: {
                    label: function(context) {
                      const value = Number(context.raw || 0);
                      return `${context.label}: ${value.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}`;
                    }
                  }
                }
              }
            }
          });
        }
      }
    });
  </script>
</div>
