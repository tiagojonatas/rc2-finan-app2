<div class="flex justify-center items-start min-h-[70vh] pt-10">
  <div class="w-full max-w-2xl">
  <div class="bg-slate-900/80 backdrop-blur border border-slate-800 rounded-2xl p-8 shadow-lg">
    <h2 class="text-2xl font-semibold text-white mb-6">Editar Despesa Fixa</h2>

    <% if (error) { %>
      <div class="mb-4 text-red-400 text-sm bg-red-500/10 border border-red-500/20 p-3 rounded-lg"><%= error %></div>
    <% } %>

    <form action="/fixed-expenses/edit/<%= expense.id %>" method="POST" class="space-y-5">
      <div>
        <label for="description" class="text-sm text-slate-400">Descricao</label>
        <input id="description" name="description" type="text" value="<%= expense.description %>" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="amount" class="text-sm text-slate-400">Valor (R$)</label>
          <input id="amount" name="amount" type="number" step="0.01" min="0" value="<%= expense.amount %>" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
        </div>
        <div>
          <label for="due_day" class="text-sm text-slate-400">Dia do vencimento</label>
          <input id="due_day" name="due_day" type="number" min="1" max="31" value="<%= expense.due_day %>" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="category_id" class="text-sm text-slate-400">Categoria ID (opcional)</label>
          <input id="category_id" name="category_id" type="number" min="1" value="<%= expense.category_id || '' %>" class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
        </div>
        <div>
          <label for="is_active" class="text-sm text-slate-400">Status</label>
          <select id="is_active" name="is_active" class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition">
            <option value="1" <%= expense.is_active ? 'selected' : '' %>>Ativa</option>
            <option value="0" <%= !expense.is_active ? 'selected' : '' %>>Inativa</option>
          </select>
        </div>
      </div>

      <div class="flex gap-4 mt-6">
        <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 px-5 py-2 rounded-lg font-medium transition">Salvar</button>
        <a href="/fixed-expenses" class="px-5 py-2 border border-slate-700 rounded-lg text-slate-300 hover:bg-slate-800 transition">Cancelar</a>
      </div>
    </form>
  </div>
  </div>
</div>
