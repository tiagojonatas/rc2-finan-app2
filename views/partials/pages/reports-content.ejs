<% const safeMonthOptions = Array.isArray(monthOptions) ? monthOptions : []; %>
<% const safeExpenseCategoryReport = Array.isArray(expenseCategoryReport) ? expenseCategoryReport : []; %>
<% const safeMonthlyBalanceData = Array.isArray(monthlyBalanceData) ? monthlyBalanceData : []; %>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-8">
  <div>
    <h1 class="text-2xl sm:text-3xl font-semibold text-white">Relatorios</h1>
    <p class="text-sm text-gray-400 mt-1"><%= selectedMonthLabel || '' %></p>
  </div>
  <form id="monthFilterForm" action="/reports" method="GET" class="bg-gray-900 border border-gray-800 rounded-lg px-3 py-2 flex items-center gap-2 shadow-sm">
    <label for="monthFilter" class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Periodo</label>
    <select id="monthFilter" name="month" class="bg-transparent text-sm font-semibold text-gray-200 focus:outline-none">
      <% safeMonthOptions.forEach((monthKey) => { %>
        <% const [year, month] = monthKey.split('-').map(Number); %>
        <% const monthLabel = new Date(year, month - 1, 1).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }); %>
        <option value="<%= monthKey %>" <%= monthKey === selectedMonth ? 'selected' : '' %>><%= monthLabel %></option>
      <% }); %>
    </select>
  </form>
</div>

<div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6">
  <div class="bg-gray-900 rounded-xl border border-gray-800 shadow-md p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Gastos por categoria</h2>
      <span class="text-xs font-medium text-emerald-300 bg-emerald-900/30 border border-emerald-800 px-2 py-1 rounded-full">Pizza</span>
    </div>
    <% if (safeExpenseCategoryReport.length === 0) { %>
      <div class="h-72 flex items-center justify-center text-gray-400 text-sm">Sem despesas no periodo</div>
    <% } else { %>
      <div class="h-72">
        <canvas id="expensePieChart"></canvas>
      </div>
    <% } %>
  </div>

  <div class="bg-gray-900 rounded-xl border border-gray-800 shadow-md p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Evolucao de saldo</h2>
      <span class="text-xs font-medium text-sky-300 bg-sky-900/30 border border-sky-800 px-2 py-1 rounded-full">Linha</span>
    </div>
    <% if (safeMonthlyBalanceData.length === 0) { %>
      <div class="h-72 flex items-center justify-center text-gray-400 text-sm">Sem historico suficiente</div>
    <% } else { %>
      <div class="h-72">
        <canvas id="balanceLineChart"></canvas>
      </div>
    <% } %>
  </div>
</div>

<div class="bg-gray-900 rounded-xl border border-gray-800 shadow-md p-5">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-white">Ranking de categorias</h2>
    <span class="text-sm font-semibold text-gray-300">Total: <%= formatCurrency(totalExpenses) %></span>
  </div>
  <% if (safeExpenseCategoryReport.length === 0) { %>
    <p class="text-sm text-gray-400">Nenhum gasto no periodo para montar ranking.</p>
  <% } else { %>
    <div class="space-y-2">
      <% safeExpenseCategoryReport.forEach((item, index) => { %>
        <div class="flex items-center justify-between rounded-lg border border-gray-800 bg-gray-950 px-4 py-3">
          <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-200 truncate flex items-center gap-2">
              <span class="inline-block w-2.5 h-2.5 rounded-full" style="background-color: <%= item.color %>;"></span>
              <span><%= index + 1 %>. <%= item.name %></span>
            </p>
            <p class="text-xs text-gray-400"><%= item.percentage.toFixed(1) %>% do total</p>
          </div>
          <p class="text-sm font-semibold text-white ml-3"><%= formatCurrency(item.total) %></p>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const monthFilter = document.getElementById('monthFilter');
    const monthFilterForm = document.getElementById('monthFilterForm');
    if (monthFilter && monthFilterForm) {
      monthFilter.addEventListener('change', function() {
        monthFilterForm.submit();
      });
    }

    const expenseCategoryReportServer = <%- JSON.stringify(safeExpenseCategoryReport) %>;
    const monthlyBalanceDataServer = <%- JSON.stringify(safeMonthlyBalanceData) %>;

    const pieCanvas = document.getElementById('expensePieChart');
    if (pieCanvas && expenseCategoryReportServer.length > 0 && typeof Chart !== 'undefined') {
      new Chart(pieCanvas, {
        type: 'pie',
        data: {
          labels: expenseCategoryReportServer.map(function(item) { return item.name; }),
          datasets: [{
            data: expenseCategoryReportServer.map(function(item) { return Number(item.total) || 0; }),
            backgroundColor: expenseCategoryReportServer.map(function(item) { return item.color || '#00C9A7'; }),
            borderColor: '#111827',
            borderWidth: 2,
            hoverOffset: 6
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom',
              labels: { usePointStyle: true, boxWidth: 8, padding: 14, color: '#d1d5db' }
            },
            tooltip: {
              callbacks: {
                label: function(context) {
                  const idx = context.dataIndex;
                  const item = expenseCategoryReportServer[idx];
                  const value = Number(context.parsed || 0);
                  const percentage = item ? Number(item.percentage || 0).toFixed(1) : '0.0';
                  return `${new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value)} (${percentage}%)`;
                }
              }
            }
          }
        }
      });
    }

    const lineCanvas = document.getElementById('balanceLineChart');
    if (lineCanvas && monthlyBalanceDataServer.length > 0 && typeof Chart !== 'undefined') {
      new Chart(lineCanvas, {
        type: 'line',
        data: {
          labels: monthlyBalanceDataServer.map(function(item) { return item.label; }),
          datasets: [{
            label: 'Saldo',
            data: monthlyBalanceDataServer.map(function(item) { return Number(item.balance) || 0; }),
            borderColor: '#00C9A7',
            backgroundColor: 'rgba(0, 201, 167, 0.15)',
            pointBackgroundColor: monthlyBalanceDataServer.map(function(item) { return (Number(item.balance) || 0) < 0 ? '#fb7185' : '#00C9A7'; }),
            pointBorderColor: '#111827',
            pointBorderWidth: 1,
            pointRadius: 3,
            borderWidth: 2,
            fill: true,
            tension: 0.3
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: {
              grid: { color: 'rgba(148, 163, 184, 0.18)' },
              ticks: {
                color: '#9ca3af',
                callback: function(value) {
                  return new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL',
                    maximumFractionDigits: 0
                  }).format(value);
                }
              }
            },
            x: {
              grid: { display: false },
              ticks: { color: '#9ca3af' }
            }
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(context) {
                  return new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }).format(context.parsed.y || 0);
                }
              }
            }
          }
        }
      });
    }
  });
</script>
