<% const safeCategories = Array.isArray(categories) ? categories : []; %>
<% const safeFormData = formData || {}; %>
<% const selectedValueType = (safeFormData.value_type === 'variable') ? 'variable' : 'fixed'; %>

<div class="flex justify-center items-start min-h-[70vh] pt-10">
  <div class="w-full max-w-2xl">
  <div class="bg-slate-900/80 backdrop-blur border border-slate-800 rounded-2xl p-8 shadow-lg">
    <h2 class="text-2xl font-semibold text-white mb-6">Nova Despesa Fixa</h2>

    <% if (error) { %>
      <div class="mb-4 text-red-400 text-sm bg-red-500/10 border border-red-500/20 p-3 rounded-lg"><%= error %></div>
    <% } %>

    <form action="/fixed-expenses/add" method="POST" class="space-y-5">
      <div>
        <label for="description" class="text-sm text-slate-400">Descricao</label>
        <input id="description" name="description" type="text" value="<%= safeFormData.description || '' %>" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
      </div>

      <div>
        <p class="text-sm text-slate-400 mb-2">Tipo de valor</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <label class="inline-flex items-center gap-2 text-sm text-slate-200">
            <input id="valueTypeFixed" type="radio" name="value_type" value="fixed" <%= selectedValueType === 'fixed' ? 'checked' : '' %> class="text-emerald-500 focus:ring-emerald-500" />
            Fixo
          </label>
          <label class="inline-flex items-center gap-2 text-sm text-slate-200">
            <input id="valueTypeVariable" type="radio" name="value_type" value="variable" <%= selectedValueType === 'variable' ? 'checked' : '' %> class="text-emerald-500 focus:ring-emerald-500" />
            Variavel (ex: energia, fatura)
          </label>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="amountDisplay" class="text-sm text-slate-400">Valor base</label>
          <input id="amountDisplay" type="text" inputmode="numeric" placeholder="Opcional para valores variaveis (ex: energia, fatura)" class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
          <input id="amount" name="amount" type="hidden" value="<%= safeFormData.amount || '' %>" />
          <p id="amountHelper" class="text-xs text-slate-500 mt-1">Para tipo Fixo, o valor e obrigatorio.</p>
        </div>
        <div>
          <label for="due_day" class="text-sm text-slate-400">Dia do vencimento</label>
          <input id="due_day" name="due_day" type="number" min="1" max="31" value="<%= safeFormData.due_day || '' %>" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="category_id" class="text-sm text-slate-400">Categoria (opcional)</label>
          <select id="category_id" name="category_id" class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition">
            <option value="">Sem categoria</option>
            <% safeCategories.forEach((category) => { %>
              <option value="<%= category.id %>" <%= String(safeFormData.category_id || '') === String(category.id) ? 'selected' : '' %>><%= category.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label for="is_active" class="text-sm text-slate-400">Cadastro ativo</label>
          <select id="is_active" name="is_active" class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition">
            <option value="1" <%= String(safeFormData.is_active || '1') === '1' ? 'selected' : '' %>>Ativa</option>
            <option value="0" <%= String(safeFormData.is_active || '1') === '0' ? 'selected' : '' %>>Inativa</option>
          </select>
        </div>
      </div>

      <div class="flex flex-col md:flex-row gap-3 md:gap-4 mt-6">
        <button type="submit" class="w-full md:w-auto h-12 bg-emerald-500 hover:bg-emerald-600 px-5 py-3 rounded-lg font-medium transition">Salvar</button>
        <a href="/fixed-expenses" class="w-full md:w-auto h-12 inline-flex items-center justify-center px-5 py-3 border border-slate-700 rounded-lg text-slate-300 hover:bg-slate-800 transition">Cancelar</a>
      </div>
    </form>
  </div>
  </div>
</div>

<script>
  (function initFixedExpenseAmountMask() {
    const amountDisplay = document.getElementById('amountDisplay');
    const amountInput = document.getElementById('amount');
    const valueTypeFixed = document.getElementById('valueTypeFixed');
    const valueTypeVariable = document.getElementById('valueTypeVariable');
    if (!amountDisplay || !amountInput || !valueTypeFixed || !valueTypeVariable) return;

    function formatBRL(value) {
      return value.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function syncDisplayFromHidden() {
      const raw = (amountInput.value || '').toString().trim();
      if (!raw) {
        amountDisplay.value = '';
        return;
      }
      const numeric = parseFloat(raw.replace(',', '.'));
      amountDisplay.value = Number.isFinite(numeric) ? formatBRL(numeric) : '';
    }

    amountDisplay.addEventListener('input', function(event) {
      const digits = event.target.value.replace(/\D/g, '');
      if (!digits) {
        amountDisplay.value = '';
        amountInput.value = '';
        return;
      }
      const value = parseInt(digits, 10) / 100;
      amountDisplay.value = formatBRL(value);
      amountInput.value = value.toFixed(2);
    });

    amountDisplay.addEventListener('paste', function(event) {
      event.preventDefault();
      const pasted = (event.clipboardData || window.clipboardData).getData('text') || '';
      const digits = pasted.replace(/\D/g, '');
      if (digits) {
        amountDisplay.value = digits;
        amountDisplay.dispatchEvent(new Event('input'));
      }
    });

    function applyValueTypeRules() {
      const isVariable = valueTypeVariable.checked;
      const amountHelper = document.getElementById('amountHelper');
      if (amountHelper) {
        amountHelper.textContent = isVariable
          ? 'Para tipo Variavel, o valor e opcional.'
          : 'Para tipo Fixo, o valor e obrigatorio.';
      }
    }

    valueTypeFixed.addEventListener('change', applyValueTypeRules);
    valueTypeVariable.addEventListener('change', applyValueTypeRules);

    syncDisplayFromHidden();
    applyValueTypeRules();
  })();
</script>

