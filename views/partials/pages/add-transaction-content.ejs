<% const safeCategories = Array.isArray(categories) ? categories : []; %>
<% const safeFormData = formData || {}; %>
<% const selectedType = safeFormData.type || defaultType || 'expense'; %>
<% const selectedPaymentMethodRaw = safeFormData.payment_method || 'cash'; %>
<% const selectedPaymentMethod = selectedPaymentMethodRaw === 'debit' ? 'pix' : selectedPaymentMethodRaw; %>
<% const safeCards = Array.isArray(cards) ? cards : []; %>
<% const selectedCardId = String(safeFormData.card_id || ''); %>
<% const isRecurringSelected = String(safeFormData.is_recurring || '') === '1' || String(safeFormData.is_recurring || '') === 'on'; %>
<% const isInstallmentSelected = String(safeFormData.is_installment || '') === '1' || String(safeFormData.is_installment || '') === 'on'; %>
<% const selectedInstallmentTotal = safeFormData.installment_total || 2; %>
<% const affectsBalanceSelected = selectedType === 'income'
  ? true
  : (typeof safeFormData.affects_balance === 'undefined'
    ? true
    : (String(safeFormData.affects_balance) === '1' || String(safeFormData.affects_balance) === 'on' || safeFormData.affects_balance === true)); %>

<div class="flex justify-center items-start min-h-[70vh] pt-10">
  <div class="w-full max-w-2xl">
    <div class="bg-slate-900/80 backdrop-blur border border-slate-800 rounded-2xl p-8 shadow-lg">
      <h2 class="text-2xl font-semibold text-white mb-6">Nova Transacao</h2>

      <% if (error) { %>
        <div class="mb-4 text-red-400 text-sm bg-red-500/10 border border-red-500/20 p-3 rounded-lg"><%= error %></div>
      <% } %>

      <form action="/transactions/add" method="POST" class="space-y-5">
        <div>
          <label for="description" class="text-sm text-slate-400">Descricao</label>
          <input id="description" name="description" type="text" value="<%= safeFormData.description || '' %>" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="amountDisplay" class="text-sm text-slate-400">Valor (R$)</label>
            <input id="amountDisplay" type="text" inputmode="numeric" placeholder="0,00" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
            <input id="amount" name="amount" type="hidden" value="<%= safeFormData.amount || '0.00' %>" />
          </div>
          <div>
            <label for="date" class="text-sm text-slate-400">Data</label>
            <input id="date" name="date" type="date" value="<%= safeFormData.date || '' %>" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="type" class="text-sm text-slate-400">Tipo</label>
            <select id="type" name="type" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition">
              <option value="income" <%= selectedType === 'income' ? 'selected' : '' %>>Entrada</option>
              <option value="expense" <%= selectedType === 'expense' ? 'selected' : '' %>>Despesa</option>
            </select>
          </div>
          <div>
            <label for="payment_method" class="text-sm text-slate-400">Forma de pagamento</label>
            <select id="payment_method" name="payment_method" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition">
              <option value="cash" <%= selectedPaymentMethod === 'cash' ? 'selected' : '' %>>Dinheiro</option>
              <option value="pix" <%= selectedPaymentMethod === 'pix' ? 'selected' : '' %>>Pix</option>
              <option value="credit" <%= selectedPaymentMethod === 'credit' ? 'selected' : '' %>>Cartao</option>
            </select>
          </div>
        </div>

        <div id="cardWrapper">
          <label for="card_id" class="text-sm text-slate-400">Cartao</label>
          <select id="card_id" name="card_id" class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition">
            <option value="">Selecione um cartao</option>
            <% safeCards.forEach((card) => { %>
              <option value="<%= card.id %>" <%= selectedCardId === String(card.id) ? 'selected' : '' %>><%= card.name %></option>
            <% }); %>
          </select>
        </div>

        <div>
          <label for="category_id" class="text-sm text-slate-400">Categoria</label>
          <select id="category_id" name="category_id" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition">
            <% safeCategories.forEach((category) => { %>
              <option value="<%= category.id %>" data-type="<%= category.type %>" <%= String(safeFormData.category_id || '') === String(category.id) ? 'selected' : '' %>>
                <%= category.name %>
              </option>
            <% }); %>
          </select>
        </div>

        <div id="recurringWrapper">
          <label for="is_recurring" class="text-sm text-slate-400">Tipo da despesa</label>
          <select id="is_recurring" name="is_recurring" class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition">
            <option value="0" <%= !isRecurringSelected ? 'selected' : '' %>>Despesa unica</option>
            <option value="1" <%= isRecurringSelected ? 'selected' : '' %>>Despesa recorrente</option>
          </select>
        </div>

        <label id="installmentWrapper" class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/70 px-3 py-3 text-sm text-slate-300">
          <input
            id="is_installment"
            name="is_installment"
            type="checkbox"
            value="1"
            <%= isInstallmentSelected ? 'checked' : '' %>
            class="h-4 w-4 rounded border-slate-600 bg-slate-900 text-emerald-500 focus:ring-emerald-500"
          />
          <span>Compra parcelada</span>
        </label>

        <div id="installmentTotalWrapper">
          <label for="installment_total" class="text-sm text-slate-400">Numero de parcelas</label>
          <input
            id="installment_total"
            name="installment_total"
            type="number"
            min="2"
            max="60"
            step="1"
            value="<%= selectedInstallmentTotal %>"
            class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 h-12 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 transition"
          />
        </div>

        <label id="affectsBalanceWrapper" class="flex items-center gap-3 rounded-lg border border-slate-700 bg-slate-800/70 px-3 py-3 text-sm text-slate-300">
          <input
            id="affects_balance"
            name="affects_balance"
            type="checkbox"
            value="1"
            <%= affectsBalanceSelected ? 'checked' : '' %>
            class="h-4 w-4 rounded border-slate-600 bg-slate-900 text-emerald-500 focus:ring-emerald-500"
          />
          <span>Impacta saldo</span>
        </label>

        <div class="flex flex-col md:flex-row gap-3 md:gap-4 mt-6">
          <button type="submit" class="w-full md:w-auto h-12 bg-emerald-500 hover:bg-emerald-600 px-5 py-3 rounded-lg font-medium transition">Salvar</button>
          <a href="/dashboard" class="w-full md:w-auto h-12 inline-flex items-center justify-center px-5 py-3 border border-slate-700 rounded-lg text-slate-300 hover:bg-slate-800 transition">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function initAddTransactionForm() {
    const amountDisplay = document.getElementById('amountDisplay');
    const amountInput = document.getElementById('amount');
    const typeSelect = document.getElementById('type');
    const categorySelect = document.getElementById('category_id');
    const recurringWrapper = document.getElementById('recurringWrapper');
    const recurringTypeSelect = document.getElementById('is_recurring');
    const affectsBalanceWrapper = document.getElementById('affectsBalanceWrapper');
    const affectsBalanceInput = document.getElementById('affects_balance');
    const paymentMethodSelect = document.getElementById('payment_method');
    const cardWrapper = document.getElementById('cardWrapper');
    const cardSelect = document.getElementById('card_id');
    const installmentWrapper = document.getElementById('installmentWrapper');
    const installmentInput = document.getElementById('is_installment');
    const installmentTotalWrapper = document.getElementById('installmentTotalWrapper');
    const installmentTotalInput = document.getElementById('installment_total');

    if (!amountDisplay || !amountInput || !typeSelect || !categorySelect || !recurringWrapper || !recurringTypeSelect || !affectsBalanceWrapper || !affectsBalanceInput || !paymentMethodSelect || !cardWrapper || !cardSelect || !installmentWrapper || !installmentInput || !installmentTotalWrapper || !installmentTotalInput) return;

    function formatBRL(value) {
      return value.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function initializeAmount() {
      const currentValue = parseFloat((amountInput.value || '0').toString().replace(',', '.')) || 0;
      amountDisplay.value = formatBRL(currentValue);
    }

    function updateCategoryOptions() {
      const selected = typeSelect.value;
      const options = Array.from(categorySelect.options);
      let visibleSelected = false;

      options.forEach((option) => {
        const isVisible = option.dataset.type === selected;
        option.hidden = !isVisible;
        if (isVisible && option.selected) visibleSelected = true;
      });

      if (!visibleSelected) {
        const firstVisible = options.find((option) => !option.hidden);
        if (firstVisible) firstVisible.selected = true;
      }
    }

    function updateRecurringVisibility() {
      const isExpense = typeSelect.value === 'expense';
      recurringWrapper.style.display = isExpense ? '' : 'none';
      if (!isExpense) recurringTypeSelect.value = '0';
    }

    function updateAffectsBalanceVisibility() {
      const isIncome = typeSelect.value === 'income';
      if (isIncome) {
        affectsBalanceInput.checked = true;
        affectsBalanceInput.disabled = true;
        affectsBalanceWrapper.style.display = 'none';
      } else {
        affectsBalanceInput.disabled = false;
        affectsBalanceWrapper.style.display = '';
      }
    }

    function updateInstallmentVisibility() {
      const isExpense = typeSelect.value === 'expense';
      installmentWrapper.style.display = isExpense ? '' : 'none';
      if (!isExpense) {
        installmentInput.checked = false;
      }
      updateInstallmentTotalVisibility();
    }

    function updateCardVisibility() {
      const isCredit = paymentMethodSelect.value === 'credit';
      cardWrapper.style.display = isCredit ? '' : 'none';
      cardSelect.required = isCredit;
      if (!isCredit) {
        cardSelect.value = '';
      }
    }

    function updateInstallmentTotalVisibility() {
      const shouldShowTotal = typeSelect.value === 'expense' && installmentInput.checked;
      installmentTotalWrapper.style.display = shouldShowTotal ? '' : 'none';
      installmentTotalInput.required = shouldShowTotal;
      installmentTotalInput.disabled = !shouldShowTotal;
      if (!shouldShowTotal) {
        installmentTotalInput.value = '2';
      } else if (!installmentTotalInput.value || Number(installmentTotalInput.value) < 2) {
        installmentTotalInput.value = '2';
      }
    }

    amountDisplay.addEventListener('input', function(event) {
      const digits = event.target.value.replace(/\D/g, '');
      if (!digits) {
        amountDisplay.value = '';
        amountInput.value = '0.00';
        return;
      }
      const numValue = parseInt(digits, 10) / 100;
      amountDisplay.value = formatBRL(numValue);
      amountInput.value = numValue.toFixed(2);
    });

    amountDisplay.addEventListener('paste', function(event) {
      event.preventDefault();
      const pasted = (event.clipboardData || window.clipboardData).getData('text') || '';
      const digits = pasted.replace(/\D/g, '');
      if (digits) {
        amountDisplay.value = digits;
        amountDisplay.dispatchEvent(new Event('input'));
      }
    });

    initializeAmount();
    updateCategoryOptions();
    updateRecurringVisibility();
    updateAffectsBalanceVisibility();
    updateCardVisibility();
    updateInstallmentVisibility();
    typeSelect.addEventListener('change', updateCategoryOptions);
    typeSelect.addEventListener('change', updateRecurringVisibility);
    typeSelect.addEventListener('change', updateAffectsBalanceVisibility);
    typeSelect.addEventListener('change', updateInstallmentVisibility);
    paymentMethodSelect.addEventListener('change', updateCardVisibility);
    installmentInput.addEventListener('change', updateInstallmentTotalVisibility);
  })();
</script>
