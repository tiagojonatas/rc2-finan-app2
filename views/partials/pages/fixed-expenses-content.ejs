<% const safeDefinitions = Array.isArray(fixedDefinitions) ? fixedDefinitions : (Array.isArray(expenses) ? expenses : []); %>
<% const safeMonthlyExpenses = Array.isArray(monthlyExpenses) ? monthlyExpenses : []; %>
<% const safeMonthOptions = Array.isArray(monthOptions) ? monthOptions : []; %>
<% const currentStatus = selectedStatus || 'all'; %>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
  <div>
    <h1 class="text-xl sm:text-3xl font-semibold text-white">Despesas Fixas</h1>
    <p class="text-sm text-gray-400 mt-1">Cadastros recorrentes e ocorrencias mensais com status de pagamento.</p>
  </div>
  <a href="/fixed-expenses/add" class="w-full sm:w-auto h-12 inline-flex items-center justify-center bg-[#00C9A7] hover:bg-[#009e83] text-white px-4 py-3 rounded-lg transition-all duration-200">+ Nova fixa</a>
</div>

<div class="mb-5 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
  <form action="/fixed-expenses" method="GET" class="bg-gray-900 border border-gray-800 rounded-lg px-3 py-2 flex flex-col sm:flex-row sm:items-center gap-2 w-full sm:w-auto">
    <div class="flex items-center gap-2">
      <label for="month" class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Periodo</label>
      <select id="month" name="month" class="bg-transparent text-sm font-semibold text-gray-200 focus:outline-none w-full sm:w-auto" onchange="this.form.submit()">
        <% safeMonthOptions.forEach((monthKey) => { %>
          <% const [year, month] = monthKey.split('-').map(Number); %>
          <% const monthLabel = new Date(year, month - 1, 1).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }); %>
          <option value="<%= monthKey %>" <%= monthKey === selectedMonth ? 'selected' : '' %>><%= monthLabel %></option>
        <% }) %>
      </select>
    </div>

    <div class="flex items-center gap-2">
      <label for="status" class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Status</label>
      <select id="status" name="status" class="bg-transparent text-sm font-semibold text-gray-200 focus:outline-none w-full sm:w-auto" onchange="this.form.submit()">
        <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>Todos</option>
        <option value="pendente" <%= currentStatus === 'pendente' ? 'selected' : '' %>>Pendente</option>
        <option value="pago" <%= currentStatus === 'pago' ? 'selected' : '' %>>Pago</option>
        <option value="atrasado" <%= currentStatus === 'atrasado' ? 'selected' : '' %>>Atrasado</option>
      </select>
    </div>
  </form>
  <p class="text-sm text-slate-400"><%= selectedMonthLabel || '' %></p>
</div>

<% if (error) { %>
  <div class="mb-4 rounded-xl border border-rose-800 bg-rose-900/30 text-rose-300 px-4 py-3"><%= error %></div>
<% } %>

<% if (success) { %>
  <div class="mb-4 rounded-xl border border-emerald-800 bg-emerald-900/30 text-emerald-300 px-4 py-3"><%= success %></div>
<% } %>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
  <section class="xl:col-span-2 bg-gray-900 rounded-xl border border-gray-800 overflow-hidden shadow-md">
    <div class="px-5 py-3 bg-gray-950 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-300">Ocorrencias do mes</h2>
      <span class="text-xs text-gray-500"><%= safeMonthlyExpenses.length %> conta(s)</span>
    </div>

    <% if (safeMonthlyExpenses.length === 0) { %>
      <div class="p-8 text-center text-gray-400">Nenhuma ocorrencia encontrada para este filtro.</div>
    <% } else { %>
      <div class="divide-y divide-gray-800">
        <% safeMonthlyExpenses.forEach((item) => { %>
          <div class="p-4 sm:p-5 hover:bg-gray-950 transition-all duration-200">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
              <div>
                <p class="font-semibold text-gray-100"><%= item.description %></p>
                <p class="text-xs text-gray-400 mt-1">Categoria: <%= item.category_name || 'Sem categoria' %> • Vence em <%= formatDate(item.due_date) %></p>
              </div>
              <div class="text-left md:text-right">
                <p class="text-lg font-semibold text-gray-100"><%= formatCurrency(item.amount) %></p>
                <% if (item.status === 'pago') { %>
                  <span class="inline-flex mt-1 px-2 py-1 rounded-full text-xs font-semibold bg-emerald-900/40 text-emerald-300 border border-emerald-800">Pago</span>
                <% } else if (item.status === 'atrasado') { %>
                  <span class="inline-flex mt-1 px-2 py-1 rounded-full text-xs font-semibold bg-rose-900/40 text-rose-300 border border-rose-800">Atrasado</span>
                <% } else { %>
                  <span class="inline-flex mt-1 px-2 py-1 rounded-full text-xs font-semibold bg-amber-900/40 text-amber-300 border border-amber-800">Pendente</span>
                <% } %>
              </div>
            </div>

            <div class="mt-3 flex flex-col sm:flex-row gap-2 sm:items-center">
              <button
                type="button"
                data-edit-value-toggle="<%= item.id %>"
                class="h-10 px-3 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 text-sm">
                Editar valor
              </button>

              <div class="flex items-center gap-2">
                <% if (item.status !== 'pago') { %>
                  <form action="/fixed-expenses/monthly/<%= item.id %>/pay" method="POST">
                    <input type="hidden" name="month" value="<%= selectedMonth %>" />
                    <input type="hidden" name="status" value="<%= currentStatus %>" />
                    <button type="submit" class="h-10 px-3 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-sm">Marcar pago</button>
                  </form>
                <% } else { %>
                  <form action="/fixed-expenses/monthly/<%= item.id %>/reopen" method="POST">
                    <input type="hidden" name="month" value="<%= selectedMonth %>" />
                    <input type="hidden" name="status" value="<%= currentStatus %>" />
                    <button type="submit" class="h-10 px-3 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 text-sm">Reabrir</button>
                  </form>
                <% } %>
              </div>
            </div>

            <form
              id="editValueForm-<%= item.id %>"
              action="/fixed-expenses/monthly/<%= item.id %>/value"
              method="POST"
              class="hidden mt-3 flex flex-col sm:flex-row sm:items-center gap-2">
              <input type="hidden" name="month" value="<%= selectedMonth %>" />
              <input type="hidden" name="status" value="<%= currentStatus %>" />
              <input type="number" step="0.01" min="0" name="amount" value="<%= Number(item.amount || 0).toFixed(2) %>" class="w-full sm:w-40 h-10 bg-slate-800 border border-slate-700 rounded-lg px-3 text-sm text-white" required />
              <button type="submit" class="h-10 px-3 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 text-sm">Salvar valor</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <section class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden shadow-md">
    <div class="px-5 py-3 bg-gray-950 border-b border-gray-800 flex items-center justify-between">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-300">Cadastros fixos</h2>
      <span class="text-xs text-gray-500"><%= safeDefinitions.length %></span>
    </div>

    <% if (safeDefinitions.length === 0) { %>
      <div class="p-6 text-center text-gray-400">Nenhuma despesa fixa cadastrada.</div>
    <% } else { %>
      <div class="divide-y divide-gray-800">
        <% safeDefinitions.forEach((expense) => { %>
          <div class="p-4">
            <p class="font-semibold text-gray-100"><%= expense.description %></p>
            <p class="text-xs text-gray-400 mt-1">Dia <%= expense.due_day %> • Categoria: <%= expense.category_name || 'Sem categoria' %></p>
            <p class="text-sm mt-1 <%= expense.amount === null ? 'text-amber-300' : 'text-gray-200' %>">
              Valor base: <%= expense.amount === null ? 'Variavel (defina no mes)' : formatCurrency(expense.amount) %>
            </p>
            <div class="mt-3 flex items-center gap-2">
              <a href="/fixed-expenses/edit/<%= expense.id %>" class="h-10 px-3 inline-flex items-center rounded-lg border border-gray-700 text-gray-300 hover:bg-gray-800 text-sm">Editar</a>
              <form action="/fixed-expenses/delete/<%= expense.id %>" method="POST" data-confirm-title="Excluir despesa fixa" data-confirm-message="Tem certeza que deseja excluir esta despesa fixa e suas ocorrencias mensais?">
                <button type="submit" class="h-10 px-3 rounded-lg bg-rose-900/30 hover:bg-rose-900/50 text-rose-300 border border-rose-800 text-sm">Excluir</button>
              </form>
              <% if (expense.is_active) { %>
                <span class="ml-auto inline-flex px-2 py-1 rounded-full text-xs font-semibold bg-emerald-900/40 text-emerald-300 border border-emerald-800">Ativa</span>
              <% } else { %>
                <span class="ml-auto inline-flex px-2 py-1 rounded-full text-xs font-semibold bg-gray-950 text-gray-400 border border-gray-700">Inativa</span>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toggleButtons = document.querySelectorAll('[data-edit-value-toggle]');
    toggleButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        const id = btn.getAttribute('data-edit-value-toggle');
        const target = document.getElementById(`editValueForm-${id}`);
        if (!target) return;
        target.classList.toggle('hidden');
      });
    });
  });
</script>
