<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
  <div>
    <p class="text-sm text-gray-400">Cartao</p>
    <h1 class="text-2xl sm:text-3xl font-semibold text-white mt-1"><%= card.name %></h1>
  </div>
  <a href="/credit-cards/<%= card.id %>/add-transaction" class="min-h-[44px] inline-flex items-center bg-[#00C9A7] hover:bg-[#009e83] text-white font-medium py-2 px-4 rounded-lg transition-all duration-200">
    + Novo gasto
  </a>
</div>

<div class="bg-gray-900 rounded-xl border border-gray-800 shadow-md p-5 mb-6">
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    <div class="rounded-lg border border-gray-800 bg-gray-950 p-3">
      <p class="text-xs text-gray-400 mb-1">Limite total</p>
      <p class="text-xl font-semibold text-white"><%= formatCurrency(card.limit_amount) %></p>
    </div>
    <div class="rounded-lg border border-gray-800 bg-gray-950 p-3">
      <p class="text-xs text-gray-400 mb-1">Gasto no mes</p>
      <p class="text-xl font-semibold text-rose-300"><%= formatCurrency(totalThisMonth) %></p>
    </div>
    <div class="rounded-lg border border-gray-800 bg-gray-950 p-3">
      <p class="text-xs text-gray-400 mb-1">Disponivel</p>
      <p class="text-xl font-semibold <%= availableLimit < 0 ? 'text-rose-300' : 'text-emerald-300' %>"><%= formatCurrency(availableLimit) %></p>
    </div>
  </div>
</div>

<% if (error) { %>
  <div class="mb-6 rounded-xl border border-rose-800 bg-rose-900/30 text-rose-300 px-4 py-3"><%= error %></div>
<% } %>

<% if (success) { %>
  <div class="mb-6 rounded-xl border border-emerald-800 bg-emerald-900/30 text-emerald-300 px-4 py-3"><%= success %></div>
<% } %>

<div class="bg-gray-900 rounded-xl shadow-md border border-gray-800">
  <% if (transactions.length === 0) { %>
    <div class="text-center py-14 px-6">
      <h3 class="text-lg font-semibold text-white mb-2">Nenhuma transacao</h3>
      <p class="text-gray-400">Adicione o primeiro gasto deste cartao.</p>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[720px]">
        <thead>
          <tr class="border-b border-gray-800 bg-gray-950">
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Descricao</th>
            <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-400">Valor</th>
            <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wide text-gray-400">Data</th>
            <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wide text-gray-400">Acoes</th>
          </tr>
        </thead>
        <tbody>
          <% transactions.forEach(transaction => { %>
            <tr class="border-b border-gray-800 last:border-b-0 hover:bg-gray-950 transition-all duration-200">
              <td class="px-5 py-4 text-sm font-medium text-gray-200"><%= transaction.description %></td>
              <td class="px-5 py-4 text-right text-sm font-semibold text-rose-300"><%= formatCurrency(transaction.amount) %></td>
              <td class="px-5 py-4 text-center text-sm text-gray-400"><%= formatDate(transaction.date) %></td>
              <td class="px-5 py-4 text-center">
                <div class="inline-flex items-center gap-3">
                  <a href="/credit-cards/<%= card.id %>/edit-transaction/<%= transaction.id %>" class="text-sm font-medium text-sky-300 hover:text-sky-200">Editar</a>
                  <form action="/credit-cards/<%= card.id %>/delete-transaction/<%= transaction.id %>" method="POST" class="inline" data-confirm-title="Excluir transacao" data-confirm-message="Tem certeza que deseja excluir esta transacao?">
                    <button type="submit" class="text-sm font-medium text-rose-300 hover:text-rose-200">Excluir</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
