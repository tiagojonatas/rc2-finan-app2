<div class="min-h-[calc(100vh-10rem)] flex items-center justify-center py-8">
  <div class="w-full max-w-lg bg-gray-900 rounded-2xl border border-gray-800 shadow-md p-8">
    <h1 class="text-2xl font-bold text-white mb-2">Editar Categoria</h1>
    <p class="text-gray-400 mb-6">Renomeie e personalize a cor da categoria.</p>

    <% if (error) { %>
      <div class="mb-4 rounded-xl border border-rose-800 bg-rose-900/30 text-rose-300 px-4 py-3"><%= error %></div>
    <% } %>

    <form action="/categories/edit/<%= category.id %>" method="POST" class="space-y-4">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-300 mb-1">Nome</label>
        <input id="name" name="name" type="text" value="<%= category.name %>" required class="w-full rounded-xl border border-gray-700 bg-gray-950 text-gray-100 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-[#00C9A7]/40 focus:border-[#00C9A7]" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-300 mb-1">Tipo</label>
          <div class="w-full rounded-xl border border-gray-700 bg-gray-950 px-3 py-2 text-gray-300">
            <%= category.type === 'income' ? 'Entrada' : 'Despesa' %>
          </div>
        </div>
        <div>
          <label for="color" class="block text-sm font-medium text-gray-300 mb-1">Cor</label>
          <input id="color" name="color" type="color" value="<%= category.color || '#00C9A7' %>" class="w-full h-10 rounded-xl border border-gray-700 px-1 py-1 bg-gray-950" />
        </div>
      </div>

      <div class="pt-2 flex gap-3">
        <button type="submit" class="bg-[#00C9A7] hover:bg-[#009e83] text-white py-2 px-5 rounded-xl transition-all duration-200">Salvar</button>
        <a href="/categories" class="bg-gray-950 border border-gray-700 text-gray-300 py-2 px-5 rounded-xl hover:bg-gray-800 transition-all duration-200">Cancelar</a>
      </div>
    </form>
  </div>
</div>
