<div class="max-w-xl mx-auto mt-10">
  <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-white mb-6">Editar Categoria</h2>

    <% if (error) { %>
      <div class="mb-4 text-red-400 text-sm"><%= error %></div>
    <% } %>

    <form action="/categories/edit/<%= category.id %>" method="POST" class="space-y-4">
      <div>
        <label for="name" class="text-sm text-slate-400">Nome</label>
        <input id="name" name="name" type="text" value="<%= category.name %>" required class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="text-sm text-slate-400">Tipo</label>
          <div class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-200">
            <%= category.type === 'income' ? 'Entrada' : 'Despesa' %>
          </div>
        </div>
        <div>
          <label for="color" class="text-sm text-slate-400">Cor</label>
          <input id="color" name="color" type="color" value="<%= category.color || '#00C9A7' %>" class="w-full mt-1 bg-slate-800 border border-slate-700 rounded-lg px-2 py-2 h-10" />
        </div>
      </div>

      <div class="flex gap-2 pt-4">
        <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white px-4 py-2 rounded-lg">Salvar</button>
        <a href="/categories" class="px-4 py-2 border border-slate-700 rounded-lg text-slate-300">Cancelar</a>
      </div>
    </form>
  </div>
</div>
