<div class="bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 relative pb-28 space-y-8 rounded-2xl">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(16,185,129,0.08),transparent_60%)] pointer-events-none"></div>
  <div class="relative z-10 flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4 mb-8">
      <div>
        <h1 class="text-xl sm:text-2xl font-semibold text-white tracking-tight">Visao Geral</h1>
        <p id="currentMonth" class="text-slate-400 text-sm mt-1.5 sm:mt-2"></p>
        <% if (typeof isFutureMonth !== 'undefined' && isFutureMonth) { %>
          <span class="mt-2 inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold border border-cyan-700 bg-cyan-900/30 text-cyan-300">
            Mes futuro (projetado)
          </span>
        <% } %>
      </div>
      <div class="w-full sm:w-auto flex flex-col sm:flex-row sm:flex-wrap items-stretch sm:items-center sm:justify-end gap-3">
        <form id="monthFilterForm" action="/dashboard" method="GET" class="w-full sm:w-auto bg-[#111827] text-gray-300 border border-gray-700 hover:bg-gray-800 rounded-lg px-4 py-3 h-12 flex items-center gap-2 transition-all duration-200">
          <label for="monthFilter" class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Periodo</label>
          <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-slate-600 text-[10px] text-slate-400 cursor-help"
                title="Meses futuros mostram despesas ja comprometidas (parcelas e recorrencias).">i</span>
          <select id="monthFilter" name="month" class="bg-transparent text-sm font-semibold text-white focus:outline-none w-full sm:w-auto">
            <% const safeMonthOptions = Array.isArray(monthOptions) ? monthOptions : []; %>
            <% safeMonthOptions.forEach((monthKey) => { %>
              <% const [year, month] = monthKey.split('-').map(Number); %>
              <% const monthLabel = new Date(year, month - 1, 1).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }); %>
              <option value="<%= monthKey %>" <%= monthKey === selectedMonth ? 'selected' : '' %>><%= monthLabel %></option>
            <% }); %>
          </select>
        </form>
        <a href="/reports" class="w-full sm:w-auto bg-[#111827] text-gray-300 border border-gray-700 hover:bg-gray-800 rounded-lg px-4 py-3 h-12 inline-flex items-center justify-center transition-all duration-200">
          Relatorios
        </a>
        <a href="/analysis" class="w-full sm:w-auto bg-[#111827] text-gray-300 border border-gray-700 hover:bg-gray-800 rounded-lg px-4 py-3 h-12 inline-flex items-center justify-center transition-all duration-200">
          Analise de gastos
        </a>
        <a href="/categories" class="w-full sm:w-auto bg-[#111827] text-gray-300 border border-gray-700 hover:bg-gray-800 rounded-lg px-4 py-3 h-12 inline-flex items-center justify-center transition-all duration-200">
          Categorias
        </a>
        <a href="/fixed-expenses" class="w-full sm:w-auto bg-[#111827] text-gray-300 border border-gray-700 hover:bg-gray-800 rounded-lg px-4 py-3 h-12 inline-flex items-center justify-center transition-all duration-200">
          Despesas fixas
        </a>
      </div>
    </div>

    <% if (typeof dashboardToast !== 'undefined' && dashboardToast) { %>
      <div id="dashboardToast"
           class="toast-enter transition-all duration-200 mb-6 bg-[#111827] text-white rounded-xl p-6 shadow-md border border-gray-800">
        <p class="text-sm font-semibold text-green-300"><%= dashboardToast %></p>
      </div>
    <% } %>

    <!-- Featured Balance Section -->
    <% const breakdown = (typeof financialBreakdown !== 'undefined' && financialBreakdown) ? financialBreakdown : {}; %>
    <% const currentRealBalance = parseFloat(typeof breakdown.currentRealBalance !== 'undefined' ? breakdown.currentRealBalance : (balance || 0)); %>
    <% const projectedMonthBalance = parseFloat(
      typeof breakdown.projectedRealBalance !== 'undefined'
        ? breakdown.projectedRealBalance
        : (balance || 0)
    ); %>
    <% const isCurrentNegative = currentRealBalance < 0; %>
    <% const isProjectedNegative = projectedMonthBalance < 0; %>
    <% const usePositiveGradient = currentRealBalance >= 0 && projectedMonthBalance >= 0; %>
    <% const amountMissingToPositive = isProjectedNegative ? Math.abs(projectedMonthBalance) : 0; %>
    <% const isPositiveNowButRiskAhead = currentRealBalance > 0 && isProjectedNegative; %>
    <% const remainingCommitments = isPositiveNowButRiskAhead ? Math.max(0, currentRealBalance - projectedMonthBalance) : 0; %>
    <div class="rounded-2xl p-6 sm:p-7 shadow-lg transition-all duration-300 border <%= usePositiveGradient ? 'bg-gradient-to-r from-emerald-500/90 to-teal-500/90 border-emerald-400/50' : 'bg-slate-900/60 backdrop-blur border-slate-800' %>">
      <% if (isPositiveNowButRiskAhead) { %>
        <div class="mb-3 flex justify-end">
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold bg-rose-900/40 text-rose-300 border border-rose-700">Risco no mes</span>
        </div>
      <% } %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4 items-start">
        <div class="text-left">
          <p class="<%= usePositiveGradient ? 'text-emerald-50/90' : 'text-slate-300/95' %> text-[11px] uppercase tracking-[0.16em] font-bold">REALIDADE ATUAL</p>
          <p class="<%= usePositiveGradient ? 'text-emerald-50/80' : 'text-slate-400' %> text-sm mt-1">Valor de entrada no mes</p>
          <p class="text-4xl sm:text-5xl font-bold tracking-tight mt-1 <%= isCurrentNegative ? 'text-rose-300' : (usePositiveGradient ? 'text-emerald-50' : 'text-emerald-400') %>">
            <%= formatCurrency(currentRealBalance) %>
          </p>
        </div>
        <div class="text-left md:pl-6 md:border-l <%= usePositiveGradient ? 'md:border-emerald-200/30' : 'md:border-slate-700/60' %>">
          <p class="text-[11px] uppercase tracking-[0.16em] font-bold <%= isProjectedNegative ? 'text-rose-300' : (usePositiveGradient ? 'text-emerald-50/90' : 'text-emerald-300') %>">PROJECAO FUTURA</p>
          <p class="text-sm mt-1 <%= isProjectedNegative ? 'text-rose-300/90' : (usePositiveGradient ? 'text-emerald-50/75' : 'text-slate-400') %>">Saldo previsto no fim do mes</p>
          <p class="text-2xl sm:text-3xl font-semibold mt-1 <%= isProjectedNegative ? 'text-rose-400' : (usePositiveGradient ? 'text-emerald-50' : 'text-emerald-300') %>">
            <%= formatCurrency(projectedMonthBalance) %>
          </p>
          <% if (isProjectedNegative) { %>
            <div class="mt-4 rounded-lg border border-rose-500/40 bg-rose-900/20 px-3 py-3">
              <div class="text-sm text-rose-200 font-semibold flex items-start gap-2 leading-5">
                <span class="inline-flex w-6 h-6 rounded-full bg-rose-500/35 border border-rose-300/50 items-center justify-center text-[12px] font-bold shrink-0">!</span>
                Voce precisa reduzir <strong class="text-rose-300"><%= formatCurrency(amountMissingToPositive) %></strong> em gastos para fechar o mes no positivo
              </div>
              <div class="mt-2 pl-8 text-xs text-rose-300/90 space-y-1">
                <p>Receitas do mes: <strong class="text-rose-200"><%= formatCurrency(totalIncome || 0) %></strong></p>
                <p>Compromissos do mes: <strong class="text-rose-200"><%= formatCurrency((breakdown.totalCommittedMonth || 0)) %></strong></p>
              </div>
            </div>
          <% } %>
        </div>
      </div>
      <% if (isPositiveNowButRiskAhead) { %>
        <div class="mt-4 text-xs text-slate-300 border-t border-slate-700/60 pt-3">
          Posicao atual: <strong class="text-cyan-300"><%= formatCurrency(currentRealBalance) %></strong>
          <span class="mx-1 text-slate-500">-></span>
          Compromissos restantes: <strong class="text-rose-300"><%= formatCurrency(remainingCommitments) %></strong>
          <span class="mx-1 text-slate-500">-></span>
          Resultado previsto: <strong class="text-rose-300"><%= formatCurrency(projectedMonthBalance) %></strong>
        </div>
      <% } %>
    </div>

    <!-- Smart Insight -->
    <% const insight = (typeof financialInsight !== 'undefined' && financialInsight) ? financialInsight : { isHealthy: true, message: 'Voce esta dentro do seu planejamento', expenseVariationPercent: 0, expenseVariationDirection: 'stable', previousMonthLabel: '' }; %>
    <% const insightMessage = isPositiveNowButRiskAhead ? 'Voce esta positivo hoje, mas ficara negativo ate o fim do mes' : insight.message; %>
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md hover:shadow-lg hover:border-emerald-500/30 transition-all duration-200 hover:scale-[1.01] text-white <%= insight.isHealthy ? 'border-emerald-800' : 'border-rose-800' %>">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-wide <%= insight.isHealthy ? 'text-emerald-300' : 'text-rose-300' %>">Insight automatico</p>
          <p class="text-base sm:text-lg font-semibold mt-1">
            <%= insightMessage %>
          </p>
        </div>
        <div class="text-sm">
          <p class="text-slate-400">Vs. <%= insight.previousMonthLabel || 'mes anterior' %></p>
          <p class="font-semibold <%= insight.expenseVariationDirection === 'up' ? 'text-rose-300' : insight.expenseVariationDirection === 'down' ? 'text-emerald-300' : 'text-gray-300' %>">
            <% if (insight.expenseVariationDirection === 'up') { %>+<% } %><%= Math.abs(insight.expenseVariationPercent || 0).toFixed(1) %>%
            em gastos
          </p>
        </div>
      </div>
    </div>

    <!-- Fixed Expenses Status -->
    <% const safeOverdueAccounts = Array.isArray(overdueAccounts) ? overdueAccounts : []; %>
    <% const safeUpcomingDueAccounts = Array.isArray(upcomingDueAccounts) ? upcomingDueAccounts : []; %>
    <div class="border-t border-slate-800/50 pt-6 space-y-4">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-lg sm:text-xl font-semibold text-white tracking-tight">Controle de obrigacoes</h2>
        <div class="flex items-center gap-2 text-[11px]">
          <span class="px-2 py-0.5 rounded-full border border-rose-700 bg-rose-900/40 text-rose-300">Atrasado</span>
          <span class="px-2 py-0.5 rounded-full border border-amber-700 bg-amber-900/40 text-amber-300">Pendente</span>
          <span class="px-2 py-0.5 rounded-full border border-emerald-700 bg-emerald-900/40 text-emerald-300">Pago</span>
        </div>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
        <section class="bg-slate-900/60 backdrop-blur border border-rose-800/60 rounded-xl p-4 shadow-md">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-rose-300">Contas em atraso</h3>
            <span class="text-xs text-rose-200"><%= safeOverdueAccounts.length %></span>
          </div>
          <% if (safeOverdueAccounts.length === 0) { %>
            <p class="text-sm text-slate-400">Nenhuma conta em atraso.</p>
          <% } else { %>
            <div class="space-y-2">
              <% safeOverdueAccounts.forEach((item) => { %>
                <div class="rounded-lg border border-rose-800/40 bg-rose-900/20 px-3 py-2 flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-white truncate"><%= item.description %></p>
                    <p class="text-xs text-rose-200 mt-1"><%= item.overdueDays %> dia(s) em atraso</p>
                  </div>
                  <p class="text-sm font-semibold text-rose-300 whitespace-nowrap"><%= formatCurrency(item.amount) %></p>
                </div>
              <% }); %>
            </div>
          <% } %>
        </section>

        <section class="bg-slate-900/60 backdrop-blur border border-amber-800/60 rounded-xl p-4 shadow-md">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-amber-300">Proximas a vencer</h3>
            <span class="text-xs text-amber-200"><%= safeUpcomingDueAccounts.length %></span>
          </div>
          <% if (safeUpcomingDueAccounts.length === 0) { %>
            <p class="text-sm text-slate-400">Nenhuma conta vence nos proximos 3 dias.</p>
          <% } else { %>
            <div class="space-y-2">
              <% safeUpcomingDueAccounts.forEach((item) => { %>
                <div class="rounded-lg border border-amber-800/40 bg-amber-900/20 px-3 py-2 flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-white truncate"><%= item.description %></p>
                    <p class="text-xs text-amber-200 mt-1">
                      <%= item.daysToDue === 0 ? 'Vence hoje' : ('Vence em ' + item.daysToDue + ' dia(s)') %>
                    </p>
                  </div>
                  <p class="text-sm font-semibold text-amber-300 whitespace-nowrap"><%= formatCurrency(item.amount) %></p>
                </div>
              <% }); %>
            </div>
          <% } %>
        </section>
      </div>
    </div>

    <!-- Monthly Summary -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 border-t border-slate-800/50 pt-6">
      <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md hover:shadow-lg hover:border-emerald-500/30 transition-all duration-200 hover:scale-[1.01]">
        <p class="text-slate-400 text-sm mb-1 font-medium uppercase tracking-wide">Receitas</p>
        <p class="text-lg font-medium tracking-tight text-green-400"><%= formatCurrency(totalIncome) %></p>
      </div>
      <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md hover:shadow-lg hover:border-emerald-500/30 transition-all duration-200 hover:scale-[1.01]">
        <p class="text-slate-400 text-sm mb-1 font-medium uppercase tracking-wide">Gastos</p>
        <p class="text-lg font-medium tracking-tight text-red-400"><%= formatCurrency(totalExpenses) %></p>
      </div>
      <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md hover:shadow-lg hover:border-emerald-500/30 transition-all duration-200 hover:scale-[1.01] text-white sm:col-span-2 lg:col-span-1">
        <p class="text-slate-400 text-sm mb-1 font-medium uppercase tracking-wide">Despesas fixas</p>
        <p class="text-lg font-medium tracking-tight text-[#00C9A7]"><%= formatCurrency(totalFixedExpenses) %></p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
        <p class="text-slate-400 text-sm mb-1 font-medium uppercase tracking-wide">Gastos realizados</p>
        <p class="text-lg font-medium tracking-tight text-rose-300"><%= formatCurrency((breakdown.realizedExpenses || 0)) %></p>
      </div>
      <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
        <p class="text-slate-400 text-sm mb-1 font-medium uppercase tracking-wide">Compromissos futuros</p>
        <p class="text-lg font-medium tracking-tight text-amber-300"><%= formatCurrency((breakdown.futureCommitments || 0)) %></p>
      </div>
      <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md">
        <p class="text-slate-400 text-sm mb-1 font-medium uppercase tracking-wide">Total comprometido do mes</p>
        <p class="text-lg font-medium tracking-tight text-cyan-300"><%= formatCurrency((breakdown.totalCommittedMonth || 0)) %></p>
        <p class="text-[11px] text-slate-400 mt-1">Gastos realizados + compromissos futuros</p>
      </div>
    </div>

    <!-- Monthly Projection -->
    <% const projection = monthlyProjection || {}; %>
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md hover:shadow-lg hover:border-emerald-500/30 transition-all duration-200 hover:scale-[1.01] border-t border-slate-800/50 pt-6">
      <div class="px-6 py-4 border-b border-gray-800">
        <h2 class="text-xl font-semibold tracking-tight text-white">Previsao de gastos do mes</h2>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 mb-5">
          <div class="rounded-lg border border-gray-800 bg-[#111827] p-4">
            <p class="text-xs uppercase tracking-wide text-slate-400 mb-1">Despesas pendentes</p>
            <p class="text-lg font-semibold tracking-tight text-white"><%= formatCurrency(projection.pendingFixedExpenses || 0) %></p>
          </div>
          <div class="rounded-lg border border-gray-800 bg-[#111827] p-4">
            <p class="text-xs uppercase tracking-wide text-slate-400 mb-1">Fixas do mes (total)</p>
            <p class="text-lg font-semibold tracking-tight text-white"><%= formatCurrency(projection.totalFixedExpenses || 0) %></p>
          </div>
          <div class="rounded-lg border border-gray-800 bg-[#111827] p-4">
            <p class="text-xs uppercase tracking-wide text-slate-400 mb-1">Saldo projetado (real)</p>
            <p class="text-lg font-semibold tracking-tight <%= projection.isRealPositive ? 'text-emerald-300' : 'text-rose-300' %>"><%= formatCurrency(projection.realProjectedBalance || 0) %></p>
            <p class="text-[11px] text-slate-400 mt-1">Baseado em despesas reais cadastradas</p>
          </div>
          <div class="rounded-lg border border-gray-800 bg-[#111827] p-4">
            <p class="text-xs uppercase tracking-wide text-slate-400 mb-1">Media variavel (3m)</p>
            <p class="text-lg font-semibold tracking-tight text-white"><%= formatCurrency(projection.averageVariableExpenses || 0) %></p>
            <p class="text-[11px] text-slate-400 mt-1">Baseado nos ultimos 3 meses</p>
          </div>
          <div class="rounded-lg border border-gray-800 bg-[#111827] p-4">
            <p class="text-xs uppercase tracking-wide text-slate-400 mb-1">Estimativa do mes (historico)</p>
            <p class="text-lg font-semibold tracking-tight text-white"><%= formatCurrency(projection.historicalEstimatedExpense || 0) %></p>
            <p class="text-[11px] text-slate-400 mt-1">Nao representa despesas ja cadastradas</p>
          </div>
        </div>
        <div class="<%= projection.isHistoricalPositive ? 'bg-cyan-900/30 border border-cyan-700 p-4 rounded-lg' : 'bg-amber-900/30 border border-amber-700 p-4 rounded-lg' %>">
          <p class="text-xs uppercase tracking-wide mb-1 <%= projection.isHistoricalPositive ? 'text-cyan-300' : 'text-amber-300' %>">Saldo estimado (historico)</p>
          <p class="text-2xl font-semibold <%= projection.isHistoricalPositive ? 'text-cyan-200' : 'text-amber-200' %>"><%= formatCurrency(projection.historicalEstimatedBalance || 0) %></p>
        </div>
      </div>
    </div>


    <!-- Credit Card Financial Summary -->
    <% const summary = (typeof creditCardSummary !== 'undefined' && creditCardSummary) ? creditCardSummary : {}; %>
    <% const cardItems = Array.isArray(summary.cards) ? summary.cards : []; %>
    <div class="border-t border-slate-800/50 pt-6">
      <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md hover:shadow-lg hover:border-emerald-500/30 transition-all duration-200 hover:scale-[1.01] text-white <%= summary.isRisk ? 'border-rose-700' : 'border-slate-800' %>">
        <div class="px-6 py-4 bg-[#111827] border-b border-gray-800">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <h2 class="text-xl font-semibold tracking-tight text-white">Painel de cartoes</h2>
            <a href="/credit-cards" class="text-sm font-medium <%= summary.isRisk ? 'text-rose-600 hover:text-rose-700' : 'text-brand-purple hover:text-brand-cyan-dark' %>">
              Gerenciar cartoes
            </a>
          </div>
        </div>

        <% if (!summary.hasCards) { %>
          <div class="px-6 py-8 text-center">
            <p class="text-gray-300 mb-4">Voce ainda nao possui cartao cadastrado.</p>
            <a href="/credit-cards/add" class="bg-[#00C9A7] text-white px-4 py-2 rounded-lg hover:bg-[#009e83] transition inline-block">
              + Adicionar Cartao
            </a>
          </div>
        <% } else { %>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <div class="rounded-lg border border-gray-800 bg-[#111827] p-4">
                <p class="text-xs uppercase tracking-wide mb-1 text-slate-400">Limite total (geral)</p>
                <p class="text-lg font-semibold tracking-tight text-white"><%= formatCurrency(summary.totalLimit) %></p>
              </div>

              <div class="rounded-lg border border-gray-800 bg-[#111827] p-4">
                <p class="text-xs uppercase tracking-wide mb-1 text-slate-400">Utilizado total</p>
                <p class="text-lg font-semibold tracking-tight <%= summary.isRisk ? 'text-rose-300' : 'text-white' %>"><%= formatCurrency(summary.currentInvoice) %></p>
                <p class="text-xs text-slate-400 mt-1">Disponivel geral: <span class="text-emerald-300 font-semibold"><%= formatCurrency(summary.availableLimit) %></span></p>
              </div>
            </div>

            <div class="space-y-4">
              <% cardItems.forEach((card) => { %>
                <div class="rounded-xl border <%= card.isRisk ? 'border-rose-700/70 bg-rose-900/20' : 'border-gray-800 bg-[#111827]' %> p-4">
                  <div class="flex items-center justify-between gap-3 mb-4">
                    <p class="text-base font-semibold text-white"><%= card.name %></p>
                    <span class="text-xs font-semibold px-2 py-1 rounded-full <%= card.isRisk ? 'bg-rose-900/40 text-rose-300 border border-rose-700' : 'bg-emerald-900/40 text-emerald-300 border border-emerald-700' %>">
                      <%= card.isRisk ? 'Atencao de limite' : 'Dentro do limite' %>
                    </span>
                  </div>

                  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-5 gap-3 mb-4">
                    <div class="rounded-lg border border-gray-800 bg-slate-900/60 p-3">
                      <p class="text-[11px] uppercase tracking-wide text-slate-400 mb-1">Limite total</p>
                      <p class="text-sm font-semibold text-white"><%= formatCurrency(card.limitAmount) %></p>
                    </div>
                    <div class="rounded-lg border border-gray-800 bg-slate-900/60 p-3">
                      <p class="text-[11px] uppercase tracking-wide text-slate-400 mb-1">Valor utilizado</p>
                      <p class="text-sm font-semibold <%= card.isRisk ? 'text-rose-300' : 'text-slate-100' %>"><%= formatCurrency(card.usedAmount) %></p>
                    </div>
                    <div class="rounded-lg border border-gray-800 bg-slate-900/60 p-3">
                      <p class="text-[11px] uppercase tracking-wide text-slate-400 mb-1">Disponivel</p>
                      <p class="text-sm font-semibold text-emerald-300"><%= formatCurrency(card.availableAmount) %></p>
                    </div>
                    <div class="rounded-lg border border-gray-800 bg-slate-900/60 p-3">
                      <p class="text-[11px] uppercase tracking-wide text-slate-400 mb-1">Fechamento</p>
                      <p class="text-sm font-semibold text-white"><%= card.nextClosingDate ? formatDate(card.nextClosingDate) : '-' %></p>
                    </div>
                    <div class="rounded-lg border border-gray-800 bg-slate-900/60 p-3">
                      <p class="text-[11px] uppercase tracking-wide text-slate-400 mb-1">Vencimento</p>
                      <p class="text-sm font-semibold text-white"><%= card.nextDueDate ? formatDate(card.nextDueDate) : '-' %></p>
                    </div>
                  </div>

                  <div class="flex items-center justify-between mb-2">
                    <p class="text-xs font-medium text-slate-400 uppercase tracking-wide">Uso do limite</p>
                    <p class="text-xs font-bold <%= card.isRisk ? 'text-rose-300' : 'text-cyan-300' %>"><%= Math.round(card.usedPercent || 0) %>%</p>
                  </div>
                  <div class="w-full h-2.5 rounded-full bg-gray-800 overflow-hidden">
                    <div
                      class="h-full rounded-full transition-all duration-500 <%= card.isRisk ? 'bg-gradient-to-r from-rose-500 to-red-600' : 'bg-[#00C9A7]' %>"
                      style="width: <%= Math.max(0, Math.min(100, card.progressPercent || 0)) %>%;">
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
            <div class="mt-4 flex items-center justify-between text-xs">
              <span class="text-slate-400">
                Cartoes cadastrados: <strong class="text-slate-200"><%= cardItems.length %></strong>
              </span>
              <% if (summary.isRisk) { %>
                <span class="font-semibold text-rose-300">Ha cartao acima de 80% do limite</span>
              <% } else { %>
                <span class="font-semibold text-emerald-300">Todos os cartoes dentro da faixa segura</span>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Transactions Section -->
    <div class="border-t border-slate-800/50 pt-6">
      <div class="flex items-center justify-between gap-3 mb-4">
        <h2 class="text-2xl font-semibold text-white flex items-center">
          <span class="w-1 h-8 bg-brand-purple rounded-full mr-3"></span>
          Ultimos 5 lancamentos
        </h2>
        <a href="/transactions" class="text-sm font-semibold text-cyan-300 hover:text-cyan-200 transition">Ver todos os lancamentos</a>
      </div>

      <% const safeTransactionGroups = Array.isArray(transactionGroups) ? transactionGroups : []; %>
      <% const latestTransactions = []; %>
      <% safeTransactionGroups.forEach((group) => { %>
        <% if (group && Array.isArray(group.transactions)) { %>
          <% group.transactions.forEach((transaction) => { %>
            <% if (latestTransactions.length < 5) { latestTransactions.push(transaction); } %>
          <% }); %>
        <% } %>
      <% }); %>

      <% if (latestTransactions.length === 0) { %>
        <div class="glass-card text-center py-16 rounded-xl border border-gray-800">
          <h3 class="text-lg font-medium text-white mb-2">Nenhum lancamento</h3>
          <p class="text-brand-purple">Adicione sua primeira transacao.</p>
        </div>
      <% } else { %>
        <div class="glass-card rounded-xl border border-gray-800 overflow-hidden max-h-[420px] overflow-y-auto">
          <% latestTransactions.forEach((transaction, index) => { %>
            <% const isInstallment = Number(transaction && transaction.installment_total ? transaction.installment_total : 1) > 1; %>
            <% const isFutureTx = Boolean(transaction && transaction.is_future); %>
            <div class="px-4 sm:px-5 py-4 transition-all duration-200 hover:bg-[#111827] <%= isFutureTx ? 'opacity-90 bg-cyan-950/10' : '' %> <%= index < latestTransactions.length - 1 ? 'border-b border-gray-800' : '' %>">
              <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-3">
                    <p class="text-sm sm:text-base font-semibold text-white leading-snug">
                      <%= transaction && transaction.description ? transaction.description : 'Sem descricao' %>
                    </p>
                    <p class="text-base sm:text-lg font-bold whitespace-nowrap <%= transaction && transaction.type === 'income' ? 'text-emerald-600' : 'text-rose-600' %>">
                      <%= transaction && transaction.type === 'income' ? '+' : '-' %><%= formatCurrency(Math.abs(transaction && transaction.amount ? transaction.amount : 0)) %>
                    </p>
                  </div>
                  <div class="flex flex-wrap items-center gap-2 mt-2">
                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold border <%= transaction && transaction.type === 'income' ? 'bg-emerald-900/40 text-emerald-300 border-emerald-700' : 'bg-rose-900/40 text-rose-300 border-rose-700' %>">
                      <%= transaction && transaction.type === 'income' ? 'Entrada' : 'Saida' %>
                    </span>
                    <% if (isInstallment) { %>
                      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold bg-violet-900/40 text-violet-300 border border-violet-700">Parcelado</span>
                    <% } %>
                    <% if (isFutureTx) { %>
                      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold bg-cyan-900/40 text-cyan-300 border border-cyan-700">Projetado</span>
                    <% } %>
                  </div>
                  <p class="text-xs text-slate-400 mt-2"><%= transaction && transaction.date ? formatDate(transaction.date) : '' %></p>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Expense Categories -->
    <% const safeExpenseCategories = Array.isArray(expenseCategoryReport) ? expenseCategoryReport : []; %>
    <div class="bg-slate-900/60 backdrop-blur border border-slate-800 rounded-xl p-4 shadow-md hover:shadow-lg hover:border-emerald-500/30 transition-all duration-200 hover:scale-[1.01] border-t border-slate-800/50 pt-6">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xl font-semibold tracking-tight text-white">Gastos por categoria</h2>
        <span class="text-xs text-slate-400">Mes atual</span>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="rounded-xl border border-gray-800 p-4 bg-[#0f172a] min-h-[260px] flex items-center justify-center">
          <% if (safeExpenseCategories.length > 0) { %>
            <canvas id="expenseCategoryChart" class="max-h-[280px]"></canvas>
          <% } else { %>
            <p class="text-sm text-slate-400">Sem despesas para exibir no grafico.</p>
          <% } %>
        </div>
        <div class="rounded-xl border border-gray-800 p-4 bg-[#0f172a]">
          <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-3">Principais categorias</h3>
          <% if (safeExpenseCategories.length === 0) { %>
            <p class="text-sm text-slate-400">Nenhuma categoria com gasto no periodo.</p>
          <% } else { %>
            <div class="space-y-2">
              <% safeExpenseCategories.slice(0, 6).forEach((item, idx) => { %>
                <div class="flex items-center justify-between rounded-lg border border-gray-800 px-3 py-2 bg-[#111827]">
                  <div class="flex items-center gap-2 min-w-0">
                    <span class="text-xs text-gray-500 w-5"><%= idx + 1 %></span>
                    <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= item.color || '#00C9A7' %>;"></span>
                    <p class="text-sm text-gray-200 truncate"><%= item.name %></p>
                  </div>
                  <div class="text-right ml-2">
                    <p class="text-sm font-semibold text-white"><%= formatCurrency(item.total || 0) %></p>
                    <p class="text-xs text-slate-400"><%= (item.percentage || 0).toFixed(1) %>%</p>
                  </div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Floating Action Menu -->
    <div class="fixed bottom-6 right-6 z-50 group">
      <div id="fabMenu"
           class="hidden mb-3 w-56 bg-slate-900 border border-slate-800 rounded-xl shadow-xl p-2 space-y-2 transition-all duration-200 origin-bottom scale-95 opacity-0">
        <a href="/transactions/add?type=income"
           class="block px-4 py-2 text-sm text-slate-300 hover:bg-slate-800 rounded-lg transition">
          Nova receita
        </a>
        <a href="/transactions/add?type=expense"
           class="block px-4 py-2 text-sm text-slate-300 hover:bg-slate-800 rounded-lg transition">
          Nova despesa
        </a>
        <button id="openCardPurchaseModal"
           type="button"
           class="block w-full text-left px-4 py-2 text-sm text-slate-300 hover:bg-slate-800 rounded-lg transition">
          Nova compra no cartao
        </button>
      </div>

      <button id="actionFab"
              type="button"
              onclick="toggleFab()"
              aria-label="Nova transacao"
              title="Nova transacao"
              class="bg-gradient-to-br from-emerald-500 to-teal-500 text-white w-14 h-14 rounded-full shadow-xl flex items-center justify-center text-xl hover:scale-110 hover:rotate-90 hover:shadow-2xl transition-all duration-200">
        +
      </button>
      <span class="pointer-events-none absolute right-0 bottom-16 whitespace-nowrap rounded-lg border border-slate-700 bg-slate-900 px-3 py-1.5 text-xs font-medium text-slate-200 opacity-0 shadow-lg transition-opacity duration-200 group-hover:opacity-100">
        Nova transacao
      </span>
    </div>

    <% const safeDashboardCards = Array.isArray(dashboardCards) ? dashboardCards : []; %>
    <div id="cardPurchaseModal" class="fixed inset-0 z-[60] hidden items-center justify-center p-4">
      <div id="cardPurchaseBackdrop" class="absolute inset-0 bg-black/30 opacity-0 transition-opacity duration-200"></div>
      <div id="cardPurchasePanel" class="bg-[#111827] text-white rounded-xl p-6 shadow-md border border-gray-800 relative w-full max-w-md opacity-0 scale-95 transition-all duration-200">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-xl font-semibold tracking-tight text-white">Nova compra no cartao</h3>
          <button id="closeCardPurchaseModal" type="button" class="text-slate-400 hover:text-gray-300 text-xl leading-none">&times;</button>
        </div>
        <% if (safeDashboardCards.length === 0) { %>
          <p class="text-sm text-slate-400 mb-4">Voce ainda nao tem cartoes cadastrados.</p>
          <a href="/credit-cards/add" class="bg-[#00C9A7] text-white px-4 py-2 rounded-lg hover:bg-[#009e83] transition inline-block">
            Adicionar cartao
          </a>
        <% } else { %>
          <div class="flex flex-col gap-2 max-h-64 overflow-auto pr-1">
            <% safeDashboardCards.forEach((card) => { %>
              <a href="/credit-cards/<%= card.id %>/add-transaction"
                 class="w-full rounded-xl border border-gray-700 bg-[#111827] hover:bg-gray-800 text-gray-300 px-4 py-3 text-sm font-semibold transition-all duration-200">
                <%= card.name %>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <script>
      // Mostrar mes atual no dashboard
      document.addEventListener('DOMContentLoaded', function() {
        const currentMonthElement = document.getElementById('currentMonth');
        const selectedMonthLabel = <%- JSON.stringify(typeof selectedMonthLabel !== 'undefined' ? selectedMonthLabel : '') %>;
        if (currentMonthElement) {
          currentMonthElement.textContent = selectedMonthLabel || '';
        }

        const monthFilter = document.getElementById('monthFilter');
        const monthFilterForm = document.getElementById('monthFilterForm');
        if (monthFilter && monthFilterForm) {
          monthFilter.addEventListener('change', function() {
            monthFilterForm.submit();
          });
        }

        const toastEl = document.getElementById('dashboardToast');
        const highlightedTxId = <%- JSON.stringify(typeof highlightedTransactionId !== 'undefined' ? highlightedTransactionId : null) %>;

        if (toastEl) {
          requestAnimationFrame(function() {
            toastEl.classList.add('toast-show');
          });

          setTimeout(function() {
            toastEl.classList.remove('toast-show');
            toastEl.classList.add('toast-enter');
          }, 2600);

          setTimeout(function() {
            if (toastEl && toastEl.parentNode) {
              toastEl.parentNode.removeChild(toastEl);
            }
          }, 3000);
        }

        if (highlightedTxId) {
          const txEl = document.querySelector(`[data-transaction-id=\"${highlightedTxId}\"]`);
          if (txEl) {
            txEl.classList.add('tx-highlight');
            txEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }

        if (window.history && window.history.replaceState) {
          const cleanUrl = new URL(window.location.href);
          cleanUrl.searchParams.delete('toast');
          cleanUrl.searchParams.delete('tx');
          window.history.replaceState({}, '', cleanUrl.pathname + cleanUrl.search + cleanUrl.hash);
        }

        const expenseCategoryChartEl = document.getElementById('expenseCategoryChart');
        if (expenseCategoryChartEl && typeof Chart !== 'undefined') {
          const expenseCategoryData = <%- JSON.stringify((Array.isArray(expenseCategoryReport) ? expenseCategoryReport : []).map((item) => ({
            name: item.name,
            total: Number(item.total || 0),
            color: item.color || '#00C9A7'
          }))) %>;

          if (expenseCategoryData.length > 0) {
            new Chart(expenseCategoryChartEl, {
              type: 'pie',
              data: {
                labels: expenseCategoryData.map((item) => item.name),
                datasets: [{
                  data: expenseCategoryData.map((item) => item.total),
                  backgroundColor: expenseCategoryData.map((item) => item.color),
                  borderColor: '#111827',
                  borderWidth: 2
                }]
              },
              options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                  legend: {
                    position: 'bottom',
                    labels: {
                      color: '#d1d5db',
                      boxWidth: 12,
                      padding: 12
                    }
                  },
                  tooltip: {
                    callbacks: {
                      label: function(context) {
                        const value = Number(context.raw || 0);
                        return `${context.label}: ${value.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}`;
                      }
                    }
                  }
                }
              }
            });
          }
        }

        const actionFab = document.getElementById('actionFab');
        const fabMenu = document.getElementById('fabMenu');
        const openCardPurchaseModalBtn = document.getElementById('openCardPurchaseModal');
        const cardPurchaseModal = document.getElementById('cardPurchaseModal');
        const cardPurchaseBackdrop = document.getElementById('cardPurchaseBackdrop');
        const cardPurchasePanel = document.getElementById('cardPurchasePanel');
        const closeCardPurchaseModalBtn = document.getElementById('closeCardPurchaseModal');
        let isFabMenuOpen = false;
        let isCardPurchaseModalOpen = false;

        function setFabMenuState(open) {
          isFabMenuOpen = open;
          if (!fabMenu) return;

          if (open) {
            fabMenu.classList.remove('hidden');
            setTimeout(function() {
              fabMenu.classList.remove('scale-95', 'opacity-0');
              fabMenu.classList.add('scale-100', 'opacity-100');
            }, 10);
          } else {
            fabMenu.classList.add('scale-95', 'opacity-0');
            fabMenu.classList.remove('scale-100', 'opacity-100');
            setTimeout(function() {
              if (!isFabMenuOpen) {
                fabMenu.classList.add('hidden');
              }
            }, 200);
          }
        }

        window.toggleFab = function toggleFab() {
          if (!fabMenu) return;
          setFabMenuState(!isFabMenuOpen);
        };

        function setCardPurchaseModalState(open) {
          isCardPurchaseModalOpen = open;
          if (!cardPurchaseModal || !cardPurchaseBackdrop || !cardPurchasePanel) return;

          if (open) {
            cardPurchaseModal.classList.remove('hidden');
            cardPurchaseModal.classList.add('flex');
            requestAnimationFrame(function() {
              cardPurchaseBackdrop.classList.remove('opacity-0');
              cardPurchaseBackdrop.classList.add('opacity-100');
              cardPurchasePanel.classList.remove('opacity-0', 'scale-95');
              cardPurchasePanel.classList.add('opacity-100', 'scale-100');
            });
          } else {
            cardPurchaseBackdrop.classList.add('opacity-0');
            cardPurchaseBackdrop.classList.remove('opacity-100');
            cardPurchasePanel.classList.add('opacity-0', 'scale-95');
            cardPurchasePanel.classList.remove('opacity-100', 'scale-100');
            setTimeout(function() {
              if (!isCardPurchaseModalOpen) {
                cardPurchaseModal.classList.add('hidden');
                cardPurchaseModal.classList.remove('flex');
              }
            }, 200);
          }
        }

        if (actionFab && fabMenu) {
          if (openCardPurchaseModalBtn) {
            openCardPurchaseModalBtn.addEventListener('click', function() {
              setFabMenuState(false);
              setCardPurchaseModalState(true);
            });
          }

          if (closeCardPurchaseModalBtn) {
            closeCardPurchaseModalBtn.addEventListener('click', function() {
              setCardPurchaseModalState(false);
            });
          }

          if (cardPurchaseBackdrop) {
            cardPurchaseBackdrop.addEventListener('click', function() {
              setCardPurchaseModalState(false);
            });
          }

          document.addEventListener('click', function(event) {
            const clickedInsideMenu = fabMenu.contains(event.target);
            const clickedFab = actionFab.contains(event.target);
            if (!clickedInsideMenu && !clickedFab) {
              setFabMenuState(false);
            }
          });

          document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
              setFabMenuState(false);
              setCardPurchaseModalState(false);
            }
          });
        }
      });
    </script>
</div>



