<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - RC2 Finance</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8fafc] font-sans text-slate-900">
  <div class="max-w-6xl mx-auto px-4 py-6">
    <header class="bg-white border border-slate-200 rounded-xl p-4 sm:p-5 shadow-sm mb-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <img src="/brand/rc2-finance-horizontal.svg" alt="RC2 Finance" class="h-9 w-auto mb-1" />
          <p class="text-xs text-slate-500">by RC2 Tecnologia</p>
          <h1 class="text-2xl font-semibold text-slate-900 mt-1">Painel Admin</h1>
        </div>
        <div class="flex items-center gap-2">
          <a href="/admin/users" class="min-h-[44px] inline-flex items-center px-4 rounded-lg bg-[#00C9A7] text-white font-medium hover:bg-[#009e83]">Usuarios</a>
          <form action="/logout" method="POST">
            <button type="submit" class="min-h-[44px] px-4 rounded-lg border border-slate-300 bg-white hover:bg-[#f8fafc] text-slate-700">Sair</button>
          </form>
        </div>
      </div>
    </header>

    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
        <p class="text-sm text-slate-500">Total de usuarios</p>
        <p class="text-3xl font-semibold mt-1"><%= totalUsers || 0 %></p>
      </div>
      <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
        <p class="text-sm text-slate-500">Total de admins</p>
        <p class="text-3xl font-semibold mt-1"><%= totalAdmins || 0 %></p>
      </div>
    </section>

    <section class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-slate-200 flex items-center justify-between">
        <h2 class="text-lg font-semibold">Usuarios cadastrados</h2>
        <a href="/admin/users/add" class="min-h-[44px] inline-flex items-center px-4 rounded-lg bg-slate-900 text-white text-sm font-medium hover:bg-slate-700">Novo usuario</a>
      </div>
      <div class="divide-y divide-slate-100">
        <% if (!users || users.length === 0) { %>
          <div class="px-5 py-8 text-slate-500">Nenhum usuario encontrado.</div>
        <% } else { %>
          <% users.forEach((user) => { %>
            <div class="px-5 py-4 flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="font-semibold"><%= user.name %></p>
                <p class="text-sm text-slate-500"><%= user.email %></p>
              </div>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold <%= user.role === 'admin' ? 'bg-cyan-100 text-cyan-700' : 'bg-[#f8fafc] text-slate-700' %>">
                <%= user.role === 'admin' ? 'ADMIN' : 'USER' %>
              </span>
            </div>
          <% }); %>
        <% } %>
      </div>
    </section>
  </div>
</body>
</html>
