<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Usuarios - RC2 Finance</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f8fafc] font-sans text-slate-900">
  <div class="max-w-6xl mx-auto px-4 py-6">
    <header class="bg-white border border-slate-200 rounded-xl p-4 sm:p-5 shadow-sm mb-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <img src="/brand/rc2-finance-horizontal.svg" alt="RC2 Finance" class="h-9 w-auto mb-1" />
          <p class="text-xs text-slate-500">by RC2 Tecnologia</p>
          <h1 class="text-2xl font-semibold text-slate-900 mt-1">Gestao de Usuarios</h1>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <a href="/admin" class="min-h-[44px] inline-flex items-center px-4 rounded-lg border border-slate-300 bg-white hover:bg-[#f8fafc]">Dashboard Admin</a>
          <a href="/admin/users/add" class="min-h-[44px] inline-flex items-center px-4 rounded-lg bg-[#00C9A7] text-white font-medium hover:bg-[#009e83]">Adicionar usuario</a>
          <form action="/logout" method="POST">
            <button type="submit" class="min-h-[44px] px-4 rounded-lg border border-slate-300 bg-white hover:bg-[#f8fafc] text-slate-700">Sair</button>
          </form>
        </div>
      </div>
    </header>

    <% if (success) { %>
      <div class="mb-4 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-700 px-4 py-3"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 text-rose-700 px-4 py-3"><%= error %></div>
    <% } %>

    <section class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
      <div class="grid grid-cols-12 px-5 py-3 bg-[#f8fafc] border-b border-slate-200 text-xs font-semibold uppercase tracking-wide text-slate-600">
        <div class="col-span-4">Nome</div>
        <div class="col-span-4">Email</div>
        <div class="col-span-2">Perfil</div>
        <div class="col-span-2 text-right">Acoes</div>
      </div>

      <% if (!users || users.length === 0) { %>
        <div class="px-5 py-8 text-slate-500">Nenhum usuario cadastrado.</div>
      <% } else { %>
        <% users.forEach((user, index) => { %>
          <div class="grid grid-cols-1 sm:grid-cols-12 gap-2 sm:gap-0 px-5 py-4 <%= index < users.length - 1 ? 'border-b border-slate-100' : '' %>">
            <div class="sm:col-span-4">
              <p class="font-semibold"><%= user.name %></p>
            </div>
            <div class="sm:col-span-4">
              <p class="text-sm text-slate-600 break-all"><%= user.email %></p>
            </div>
            <div class="sm:col-span-2">
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold <%= user.role === 'admin' ? 'bg-cyan-100 text-cyan-700' : 'bg-[#f8fafc] text-slate-700' %>">
                <%= user.role === 'admin' ? 'ADMIN' : 'USER' %>
              </span>
            </div>
            <div class="sm:col-span-2 flex sm:justify-end gap-2">
              <a href="/admin/users/edit/<%= user.id %>" class="min-h-[44px] inline-flex items-center px-3 rounded-lg bg-[#f8fafc] hover:bg-slate-200 text-slate-700 text-sm">Editar</a>
              <form action="/admin/users/delete/<%= user.id %>" method="POST" data-confirm-title="Excluir usuario" data-confirm-message="Tem certeza que deseja excluir este usuario?">
                <button type="submit" class="min-h-[44px] inline-flex items-center px-3 rounded-lg bg-rose-50 hover:bg-rose-100 text-rose-700 text-sm"
                        <%= Number(currentUserId) === Number(user.id) ? 'disabled' : '' %>>
                  Excluir
                </button>
              </form>
            </div>
          </div>
        <% }); %>
      <% } %>
    </section>
  </div>

  <div id="confirmModal" class="fixed inset-0 z-[90] hidden items-center justify-center p-4">
    <div id="confirmBackdrop" class="absolute inset-0 bg-slate-900/50 opacity-0 transition-opacity duration-200"></div>
    <div id="confirmPanel" class="relative w-full max-w-sm rounded-2xl border border-slate-200 bg-white p-5 shadow-xl opacity-0 scale-95 transition-all duration-200">
      <h3 id="confirmTitle" class="text-lg font-semibold text-slate-900">Confirmar acao</h3>
      <p id="confirmMessage" class="mt-2 text-sm text-slate-600">Tem certeza que deseja continuar?</p>
      <div class="mt-5 flex items-center justify-end gap-2">
        <button id="confirmCancel" type="button" class="min-h-[40px] px-4 py-2 rounded-lg border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 transition-all duration-200">Cancelar</button>
        <button id="confirmSubmit" type="button" class="min-h-[40px] px-4 py-2 rounded-lg bg-rose-600 text-white hover:bg-rose-700 transition-all duration-200">Excluir</button>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const confirmModal = document.getElementById('confirmModal');
      const confirmBackdrop = document.getElementById('confirmBackdrop');
      const confirmPanel = document.getElementById('confirmPanel');
      const confirmTitle = document.getElementById('confirmTitle');
      const confirmMessage = document.getElementById('confirmMessage');
      const confirmCancel = document.getElementById('confirmCancel');
      const confirmSubmit = document.getElementById('confirmSubmit');
      let pendingForm = null;
      let isOpen = false;

      function setState(open) {
        isOpen = open;
        if (open) {
          confirmModal.classList.remove('hidden');
          confirmModal.classList.add('flex');
          requestAnimationFrame(function() {
            confirmBackdrop.classList.remove('opacity-0');
            confirmBackdrop.classList.add('opacity-100');
            confirmPanel.classList.remove('opacity-0', 'scale-95');
            confirmPanel.classList.add('opacity-100', 'scale-100');
          });
        } else {
          confirmBackdrop.classList.add('opacity-0');
          confirmBackdrop.classList.remove('opacity-100');
          confirmPanel.classList.add('opacity-0', 'scale-95');
          confirmPanel.classList.remove('opacity-100', 'scale-100');
          setTimeout(function() {
            if (!isOpen) {
              confirmModal.classList.add('hidden');
              confirmModal.classList.remove('flex');
            }
          }, 200);
        }
      }

      function closeModal() {
        pendingForm = null;
        setState(false);
      }

      document.querySelectorAll('form[data-confirm-message]').forEach(function(form) {
        form.addEventListener('submit', function(event) {
          event.preventDefault();
          pendingForm = form;
          confirmTitle.textContent = form.getAttribute('data-confirm-title') || 'Confirmar acao';
          confirmMessage.textContent = form.getAttribute('data-confirm-message') || 'Tem certeza que deseja continuar?';
          setState(true);
        });
      });

      confirmCancel.addEventListener('click', closeModal);
      confirmBackdrop.addEventListener('click', closeModal);
      confirmSubmit.addEventListener('click', function() {
        if (!pendingForm) {
          closeModal();
          return;
        }
        const target = pendingForm;
        pendingForm = null;
        setState(false);
        target.submit();
      });
      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && isOpen) {
          closeModal();
        }
      });
    });
  </script>
</body>
</html>
