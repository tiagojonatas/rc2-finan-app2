<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - Sistema Financeiro</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Sora', 'ui-sans-serif', 'system-ui', 'sans-serif']
          },
          boxShadow: {
            premium: '0 28px 70px -28px rgba(15, 0, 45, 0.85), 0 12px 30px -18px rgba(130, 30, 255, 0.55)'
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px) scale(0.98);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    .login-fade {
      animation: fadeInUp 620ms ease-out both;
    }
  </style>
</head>
<body class="min-h-screen font-sans bg-slate-950 text-white">
  <div class="relative min-h-screen overflow-hidden bg-gradient-to-br from-purple-900 via-purple-700 to-indigo-900">
    <div class="pointer-events-none absolute -top-24 left-1/2 h-[28rem] w-[28rem] -translate-x-1/2 rounded-full bg-white/20 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-8rem] right-[-6rem] h-80 w-80 rounded-full bg-indigo-300/25 blur-3xl"></div>
    <div class="pointer-events-none absolute inset-0 opacity-70" style="background: radial-gradient(circle at 22% 20%, rgba(255, 255, 255, 0.22), transparent 45%), radial-gradient(circle at 80% 75%, rgba(147, 197, 253, 0.24), transparent 42%);"></div>

    <div class="relative z-10 min-h-screen flex items-center justify-center px-4 py-10">
      <div class="login-fade relative w-full max-w-md overflow-hidden rounded-2xl border border-white/10 bg-white/[0.08] p-7 sm:p-9 backdrop-blur-lg shadow-premium">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-20 bg-gradient-to-b from-white/20 via-white/5 to-transparent"></div>

        <div class="relative mb-8 text-center">
          <p class="text-xs uppercase tracking-[0.24em] text-purple-100/85 font-semibold">RC2 Finance</p>
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-white">Entrar na sua conta</h1>
          <p class="mt-2 text-sm text-purple-200/85">Acesse sua conta e acompanhe sua vida financeira com clareza e controle.</p>
        </div>

        <form id="loginForm" class="relative space-y-5" action="/login" method="POST">
          <div>
            <label for="email" class="mb-1.5 block text-xs font-medium tracking-wide text-purple-100/85">Email</label>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-gray-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 6h16v12H4z" />
                  <path d="m22 7-10 7L2 7" />
                </svg>
              </span>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="voce@exemplo.com"
                class="w-full rounded-lg border border-white/20 bg-white/20 py-3 pl-10 pr-3 text-white placeholder:text-purple-100/60 outline-none transition-all duration-200 focus:scale-[1.02] focus:ring-2 focus:ring-purple-400 focus:border-purple-300"
              >
            </div>
          </div>

          <div>
            <label for="password" class="mb-1.5 block text-xs font-medium tracking-wide text-purple-100/85">Senha</label>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-gray-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="4" y="11" width="16" height="9" rx="2" />
                  <path d="M8 11V8a4 4 0 1 1 8 0v3" />
                </svg>
              </span>
              <input
                id="password"
                name="password"
                type="password"
                required
                placeholder="Sua senha"
                class="w-full rounded-lg border border-white/20 bg-white/20 py-3 pl-10 pr-20 text-white placeholder:text-purple-100/60 outline-none transition-all duration-200 focus:scale-[1.02] focus:ring-2 focus:ring-purple-400 focus:border-purple-300"
              >
              <button
                type="button"
                id="togglePassword"
                class="absolute inset-y-0 right-3 text-xs font-semibold text-purple-200 hover:text-white transition-colors duration-200"
              >
                Mostrar
              </button>
            </div>
          </div>

          <% if (error) { %>
            <div class="rounded-lg border border-rose-300/45 bg-rose-400/15 px-3 py-2 text-sm text-rose-100">
              <%= error %>
            </div>
          <% } %>

          <button
            id="submitButton"
            type="submit"
            class="w-full rounded-lg bg-gradient-to-r from-purple-500 to-purple-700 py-3 text-sm font-semibold text-white shadow-lg shadow-purple-500/40 transition-all duration-200 hover:scale-105 active:scale-95 disabled:cursor-not-allowed disabled:opacity-80"
          >
            <span id="submitButtonText">Entrar</span>
          </button>

          <p class="text-center text-sm text-gray-200">
            Nao tem conta?
            <a href="/register" class="font-semibold text-purple-200 hover:underline">Registrar</a>
          </p>

          <p class="pt-2 text-center text-xs text-purple-100/80">Seus dados sao protegidos &#128274;</p>
        </form>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const form = document.getElementById('loginForm');
      const submitButton = document.getElementById('submitButton');
      const submitButtonText = document.getElementById('submitButtonText');
      const passwordInput = document.getElementById('password');
      const togglePasswordButton = document.getElementById('togglePassword');

      togglePasswordButton.addEventListener('click', function () {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        togglePasswordButton.textContent = isPassword ? 'Ocultar' : 'Mostrar';
      });

      form.addEventListener('submit', function () {
        submitButton.disabled = true;
        submitButtonText.textContent = 'Entrando...';
      });
    })();
  </script>
</body>
</html>
