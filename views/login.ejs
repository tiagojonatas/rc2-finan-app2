<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - RC2 Finance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Sora', 'ui-sans-serif', 'system-ui', 'sans-serif']
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-[#0f172a] via-[#111827] to-[#020617] min-h-screen font-sans text-white">
  <div class="bg-gradient-to-br from-[#0f172a] via-[#111827] to-[#020617] min-h-screen">
    <div class="min-h-screen max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-10 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-center">
      <section class="hidden lg:block opacity-60 blur-[0.2px]">
        <img src="/brand/rc2-finance-horizontal.svg" alt="RC2 Finance" class="h-11 w-auto mb-5" />
        <p class="text-xs text-gray-500 mb-4">by RC2 Tecnologia</p>

        <h1 class="text-2xl font-bold text-white/95 max-w-xl">
          Controle total da sua vida financeira
        </h1>
        <p class="mt-3 text-gray-400/90 max-w-lg text-base">
          Organize receitas, despesas e cartoes em um unico painel com visao clara do seu mes.
        </p>

        <div class="mt-6 space-y-2.5 max-w-lg">
          <div class="flex items-start gap-3 rounded-lg border border-white/10 bg-white/[0.04] px-3.5 py-2.5">
            <span class="text-[#00C9A7] mt-0.5 font-bold">-</span>
            <p class="text-sm text-gray-400">Categorias e controle de gastos</p>
          </div>
          <div class="flex items-start gap-3 rounded-lg border border-white/10 bg-white/[0.04] px-3.5 py-2.5">
            <span class="text-[#00C9A7] mt-0.5 font-bold">-</span>
            <p class="text-sm text-gray-400">Gestao inteligente de cartoes</p>
          </div>
          <div class="flex items-start gap-3 rounded-lg border border-white/10 bg-white/[0.04] px-3.5 py-2.5">
            <span class="text-[#00C9A7] mt-0.5 font-bold">-</span>
            <p class="text-sm text-gray-400">Previsao financeira mensal</p>
          </div>
        </div>
      </section>

      <section class="w-full max-w-xl lg:max-w-lg lg:justify-self-end bg-white/10 backdrop-blur-xl border border-white/10 rounded-2xl shadow-2xl p-8 sm:p-9 text-white">
        <div class="mb-6 text-center">
          <img src="/brand/rc2-finance-horizontal.svg" alt="RC2 Finance" class="h-10 w-auto mx-auto" />
          <p class="mt-1 text-xs tracking-wide text-gray-400">by RC2 Tecnologia</p>
          <h2 class="mt-3 text-2xl font-bold text-white">Acesse sua conta</h2>
          <p class="mt-2 text-sm text-gray-400">Acesse sua conta e acompanhe sua vida financeira com clareza e controle.</p>
        </div>

        <form id="loginForm" class="space-y-4" action="/login" method="POST">
          <div>
            <label for="email" class="mb-1.5 block text-xs font-medium tracking-wide text-gray-400">Email</label>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 6h16v12H4z" />
                  <path d="m22 7-10 7L2 7" />
                </svg>
              </span>
              <input id="email" name="email" type="email" required autofocus placeholder="voce@exemplo.com"
                value="<%= email || '' %>"
                class="w-full h-12 bg-white/10 border border-white/20 text-white placeholder-gray-400 rounded-lg px-4 py-3 pl-10 pr-3 focus:ring-2 focus:ring-[#00C9A7] outline-none">
            </div>
          </div>

          <div>
            <label for="password" class="mb-1.5 block text-xs font-medium tracking-wide text-gray-400">Senha</label>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="4" y="11" width="16" height="9" rx="2" />
                  <path d="M8 11V8a4 4 0 1 1 8 0v3" />
                </svg>
              </span>
              <input id="password" name="password" type="password" required placeholder="Sua senha"
                class="w-full h-12 bg-white/10 border border-white/20 text-white placeholder-gray-400 rounded-lg px-4 py-3 pl-10 pr-14 focus:ring-2 focus:ring-[#00C9A7]">
              <button type="button" id="togglePassword" class="absolute inset-y-0 right-1.5 h-12 w-12 inline-flex items-center justify-center rounded-lg text-[#00C9A7] hover:text-[#3A86FF] transition-all duration-200" aria-label="Mostrar senha">
                <svg id="eyeOpenIcon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg id="eyeClosedIcon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-6.5 0-10-7-10-7a21.77 21.77 0 0 1 5.06-6.94"/>
                  <path d="M1 1l22 22"/>
                  <path d="M9.53 9.53a3 3 0 0 0 4.24 4.24"/>
                  <path d="M14.47 14.47A3 3 0 0 0 9.53 9.53"/>
                  <path d="M21 12s-1.78 3.56-5.06 5.94"/>
                </svg>
              </button>
            </div>
            <div class="mt-2 text-right">
              <a href="#" class="text-xs text-gray-400 hover:text-[#00C9A7] transition-all duration-200">Esqueci minha senha</a>
            </div>
            <% if (error) { %>
              <p class="mt-3 text-sm text-rose-700 bg-rose-50 border border-rose-200 rounded-lg px-3 py-2"><%= error %></p>
            <% } %>
          </div>

          <button id="submitButton" type="submit"
            class="bg-[#00C9A7] hover:bg-[#009e83] disabled:bg-[#009e83]/70 disabled:cursor-not-allowed text-white font-semibold h-12 px-4 py-3 rounded-lg w-full inline-flex items-center justify-center gap-2 transition-all duration-200">
            <svg id="submitSpinner" class="hidden h-4 w-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
            </svg>
            <span id="submitButtonText">Entrar</span>
          </button>

          <p class="text-sm text-gray-400 text-center">
            Ainda nao tem conta?
            <a href="/register" class="font-semibold text-[#00C9A7] hover:text-[#3A86FF] transition-all duration-200">Registrar</a>
          </p>

          <p class="pt-1 text-center text-xs text-gray-400 inline-flex items-center justify-center w-full gap-1">
            Seus dados sao protegidos com criptografia
            <span aria-hidden="true">&#128274;</span>
          </p>
        </form>
      </section>
    </div>
  </div>

  <script>
    (function () {
      const form = document.getElementById('loginForm');
      const submitButton = document.getElementById('submitButton');
      const submitButtonText = document.getElementById('submitButtonText');
      const submitSpinner = document.getElementById('submitSpinner');
      const passwordInput = document.getElementById('password');
      const togglePasswordButton = document.getElementById('togglePassword');
      const eyeOpenIcon = document.getElementById('eyeOpenIcon');
      const eyeClosedIcon = document.getElementById('eyeClosedIcon');

      togglePasswordButton.addEventListener('click', function () {
        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        if (eyeOpenIcon && eyeClosedIcon) {
          eyeOpenIcon.classList.toggle('hidden', isPassword);
          eyeClosedIcon.classList.toggle('hidden', !isPassword);
        }
        togglePasswordButton.classList.toggle('text-[#3A86FF]', isPassword);
        togglePasswordButton.classList.toggle('text-[#00C9A7]', !isPassword);
      });

      form.addEventListener('submit', function () {
        if (submitButton.disabled) {
          return;
        }
        submitButton.disabled = true;
        submitButton.setAttribute('aria-busy', 'true');
        if (submitSpinner) submitSpinner.classList.remove('hidden');
        submitButtonText.textContent = 'Entrando...';
      });
    })();
  </script>
</body>
</html>
