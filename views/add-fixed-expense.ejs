<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nova Despesa Fixa - Sistema Financeiro</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            'sans': ['Inter', 'system-ui', 'sans-serif'],
          },
          colors: {
            'custom-bg': '#f1f5f9',
            'brand-purple': '#8A05BE',
            'brand-purple-dark': '#6A047E'
          }
        }
      }
    }
  </script>
</head>
<body class="bg-custom-bg font-sans">
  <div class="min-h-screen flex items-center justify-center py-10 px-4">
    <div class="w-full max-w-xl bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Nova Despesa Fixa</h1>
      <p class="text-gray-600 mb-6">Cadastre uma despesa recorrente mensal.</p>

      <% if (error) { %>
        <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 text-rose-700 px-4 py-3"><%= error %></div>
      <% } %>

      <form action="/fixed-expenses/add" method="POST" class="space-y-4">
        <div>
          <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Descricao</label>
          <input id="description" name="description" type="text" required class="w-full rounded-xl border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-purple/30 focus:border-brand-purple" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="amount" class="block text-sm font-medium text-gray-700 mb-1">Valor (R$)</label>
            <input id="amount" name="amount" type="number" step="0.01" min="0" required class="w-full rounded-xl border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-purple/30 focus:border-brand-purple" />
          </div>
          <div>
            <label for="due_day" class="block text-sm font-medium text-gray-700 mb-1">Dia do vencimento</label>
            <input id="due_day" name="due_day" type="number" min="1" max="31" required class="w-full rounded-xl border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-purple/30 focus:border-brand-purple" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="category_id" class="block text-sm font-medium text-gray-700 mb-1">Categoria ID (opcional)</label>
            <input id="category_id" name="category_id" type="number" min="1" class="w-full rounded-xl border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-purple/30 focus:border-brand-purple" />
          </div>
          <div>
            <label for="is_active" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select id="is_active" name="is_active" class="w-full rounded-xl border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-purple/30 focus:border-brand-purple">
              <option value="1">Ativa</option>
              <option value="0">Inativa</option>
            </select>
          </div>
        </div>

        <div class="pt-2 flex gap-3">
          <button type="submit" class="bg-brand-purple hover:bg-brand-purple-dark text-white py-2 px-5 rounded-xl transition-colors">Salvar</button>
          <a href="/fixed-expenses" class="bg-white border border-gray-300 text-gray-700 py-2 px-5 rounded-xl hover:bg-gray-50 transition-colors">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
