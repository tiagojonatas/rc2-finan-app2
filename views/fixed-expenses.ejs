<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Despesas Fixas - Sistema Financeiro</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            'sans': ['Inter', 'system-ui', 'sans-serif'],
          },
          colors: {
            'custom-bg': '#f1f5f9',
            'brand-purple': '#8A05BE',
            'brand-purple-dark': '#6A047E',
            'brand-purple-50': '#F8F0FF',
            'brand-purple-100': '#E9D5FF'
          }
        }
      }
    }
  </script>
</head>
<body class="bg-custom-bg font-sans">
  <div class="container mx-auto px-6 py-6 max-w-5xl">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Despesas Fixas</h1>
      <div class="flex gap-3">
        <a href="/dashboard" class="bg-white border border-gray-300 text-gray-700 py-2 px-4 rounded-xl hover:bg-gray-50 transition-colors">Dashboard</a>
        <a href="/fixed-expenses/add" class="bg-brand-purple hover:bg-brand-purple-dark text-white py-2 px-4 rounded-xl transition-colors">+ Nova Despesa Fixa</a>
      </div>
    </div>

    <% if (error) { %>
      <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 text-rose-700 px-4 py-3"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="mb-4 rounded-xl border border-emerald-200 bg-emerald-50 text-emerald-700 px-4 py-3"><%= success %></div>
    <% } %>

    <% if (!expenses || expenses.length === 0) { %>
      <div class="rounded-2xl border border-brand-purple-100 bg-white p-10 text-center">
        <h2 class="text-xl font-semibold text-gray-900 mb-2">Nenhuma despesa fixa cadastrada</h2>
        <p class="text-gray-600 mb-6">Cadastre suas recorrencias mensais para acompanhar melhor o orçamento.</p>
        <a href="/fixed-expenses/add" class="inline-block bg-brand-purple hover:bg-brand-purple-dark text-white py-2 px-5 rounded-xl transition-colors">Cadastrar agora</a>
      </div>
    <% } else { %>
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
        <div class="grid grid-cols-12 gap-2 px-5 py-3 bg-brand-purple-50/60 border-b border-brand-purple-100 text-xs font-semibold uppercase tracking-wide text-gray-600">
          <div class="col-span-4">Descricao</div>
          <div class="col-span-2 text-right">Valor</div>
          <div class="col-span-2 text-center">Vencimento</div>
          <div class="col-span-2 text-center">Status</div>
          <div class="col-span-2 text-right">Acoes</div>
        </div>
        <% expenses.forEach((expense, index) => { %>
          <div class="grid grid-cols-12 gap-2 items-center px-5 py-4 <%= index < expenses.length - 1 ? 'border-b border-gray-100' : '' %> hover:bg-brand-purple-50/20 transition-colors">
            <div class="col-span-4">
              <p class="font-semibold text-gray-900"><%= expense.description %></p>
              <p class="text-xs text-gray-500">Categoria ID: <%= expense.category_id || '-' %></p>
            </div>
            <div class="col-span-2 text-right font-semibold text-gray-900"><%= formatCurrency(expense.amount) %></div>
            <div class="col-span-2 text-center text-gray-700">Dia <%= expense.due_day %></div>
            <div class="col-span-2 text-center">
              <% if (expense.is_active) { %>
                <span class="inline-flex px-2 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-700">Ativa</span>
              <% } else { %>
                <span class="inline-flex px-2 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">Inativa</span>
              <% } %>
            </div>
            <div class="col-span-2 flex justify-end gap-2">
              <a href="/fixed-expenses/edit/<%= expense.id %>" class="text-xs px-3 py-1.5 rounded-lg bg-gray-100 hover:bg-brand-purple-100 text-gray-700">Editar</a>
              <form action="/fixed-expenses/delete/<%= expense.id %>" method="POST" onsubmit="return confirm('Excluir esta despesa fixa?');">
                <button type="submit" class="text-xs px-3 py-1.5 rounded-lg bg-rose-50 hover:bg-rose-100 text-rose-700">Excluir</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</body>
</html>
