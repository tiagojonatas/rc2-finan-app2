<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard - Sistema Financeiro</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            'sans': ['Inter', 'system-ui', 'sans-serif'],
          },
          colors: {
            'custom-bg': '#f1f5f9',
          }
        }
      }
    }
  </script>
  <style>
    body {
      background-color: #f1f5f9;
      font-family: 'Inter', system-ui, sans-serif;
    }
  </style>
</head>
<body class="bg-custom-bg font-sans">
  <div class="container mx-auto px-6 py-6 max-w-5xl">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
        <p id="currentMonth" class="text-lg text-gray-600 mt-2 font-medium"></p>
      </div>
      <form action="/logout" method="POST">
        <button type="submit" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition-all duration-200 hover:scale-105 border border-gray-300">
          Sair
        </button>
      </form>
    </div>

    <!-- Featured Balance Section -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 mb-8 hover:shadow-xl transition-all duration-200">
      <div class="text-center">
        <h2 class="text-lg font-medium text-gray-600 mb-2">Saldo disponível</h2>
        <p class="text-6xl font-bold <%= balance >= 0 ? 'text-[#8A05BE]' : 'text-rose-500' %> mb-2">
          R$ <%= balance %>
        </p>
      </div>
    </div>

    <!-- Secondary Financial Summary -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-200">
        <div>
          <h3 class="text-base font-medium text-gray-600">Entradas</h3>
          <p class="text-2xl font-bold text-emerald-500 mt-1">R$ <%= totalIncome %></p>
        </div>
      </div>
      <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-200">
        <div>
          <h3 class="text-base font-medium text-gray-600">Despesas</h3>
          <p class="text-2xl font-bold text-rose-500 mt-1">R$ <%= totalExpenses %></p>
        </div>
      </div>
    </div>

    <!-- Transactions List -->
    <div class="bg-white p-6 rounded-xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900">Transações</h2>
      </div>

      <% if (transactions.length === 0) { %>
        <div class="text-center py-16">
          <h3 class="text-lg font-medium text-gray-900 mb-2">Nenhuma transação</h3>
          <p class="text-gray-500">Adicione sua primeira transação.</p>
        </div>
      <% } else { %>
        <div class="divide-y divide-gray-100">
          <% transactions.forEach((transaction, index) => { %>
            <div class="flex items-center justify-between py-4 px-2 hover:bg-gray-50 transition-all duration-200 rounded-lg hover:px-4 -mx-2 group">
              <!-- Left side - Icon, Description, Date -->
              <div class="flex items-center space-x-4 flex-1">
                <!-- Transaction Icon -->
                <div class="w-12 h-12 rounded-full flex items-center justify-center <%= transaction.type === 'income' ? 'bg-emerald-100' : 'bg-rose-100' %> transition-all duration-200 group-hover:scale-110">
                  <span class="text-lg <%= transaction.type === 'income' ? 'text-emerald-600' : 'text-rose-600' %>">
                    <%= transaction.type === 'income' ? '↓' : '↑' %>
                  </span>
                </div>

                <!-- Description and Details -->
                <div class="flex-1">
                  <div class="flex items-center space-x-2">
                    <h3 class="font-bold text-gray-900 text-lg">
                      <%= transaction.description %>
                    </h3>
                    <span class="text-xs px-2 py-1 rounded-full <%= transaction.type === 'income' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %> font-medium transition-all duration-200 group-hover:scale-105">
                      <%= transaction.type === 'income' ? 'Entrada' : 'Saída' %>
                    </span>
                  </div>
                  <p class="text-sm text-gray-400 mt-1">
                    <%= new Date(transaction.date).toLocaleDateString('pt-BR', {
                      day: '2-digit',
                      month: 'short',
                      year: 'numeric'
                    }) %>
                  </p>
                </div>
              </div>

              <!-- Right side - Amount and Actions -->
              <div class="flex items-center space-x-4">
                <!-- Amount -->
                <div class="text-right">
                  <p class="text-2xl font-bold <%= transaction.type === 'income' ? 'text-emerald-600' : 'text-rose-600' %> transition-all duration-200 group-hover:scale-105">
                    <%= transaction.type === 'income' ? '+' : '-' %>R$ <%= parseFloat(transaction.amount).toFixed(2) %>
                  </p>
                </div>

                <!-- Action Buttons -->
                <div class="flex space-x-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                  <a href="/transactions/edit/<%= transaction.id %>"
                     class="bg-gray-100 hover:bg-gray-200 text-gray-600 p-2 rounded-lg transition-all duration-200 hover:scale-110"
                     title="Editar">
                    ✏️
                  </a>
                  <form action="/transactions/delete/<%= transaction.id %>" method="POST"
                        class="inline"
                        onsubmit="return confirm('Tem certeza que deseja excluir esta transação?')">
                    <button type="submit"
                            class="bg-gray-100 hover:bg-red-100 text-gray-600 hover:text-red-600 p-2 rounded-lg transition-all duration-200 hover:scale-110"
                            title="Excluir">
                      🗑️
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Floating Action Button (FAB) -->
    <a href="/transactions/add"
       class="fixed bottom-6 right-6 w-16 h-16 bg-[#8A05BE] hover:bg-[#6A047E] rounded-full shadow-2xl hover:shadow-3xl flex items-center justify-center text-white text-3xl font-bold transition-all duration-300 hover:scale-110 hover:rotate-90 z-50"
       title="Adicionar Transação">
      +
    </a>

    <script>
      // Mostrar mês atual no dashboard
      document.addEventListener('DOMContentLoaded', function() {
        const currentMonthElement = document.getElementById('currentMonth');
        const now = new Date();
        const monthNames = [
          'Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho',
          'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'
        ];
        const currentMonth = monthNames[now.getMonth()];
        const currentYear = now.getFullYear();
        currentMonthElement.textContent = `${currentMonth} ${currentYear}`;
      });
    </script>
  </div>
</body>
</html>