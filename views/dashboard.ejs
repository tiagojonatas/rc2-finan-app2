<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard - Sistema Financeiro</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            'sans': ['Inter', 'system-ui', 'sans-serif'],
          },
          colors: {
            'custom-bg': '#f5f6fa',
          }
        }
      }
    }
  </script>
  <style>
    body {
      background-color: #f5f6fa;
      font-family: 'Inter', system-ui, sans-serif;
    }
  </style>
</head>
<body class="bg-custom-bg font-sans">
  <div class="container mx-auto px-5 py-5" style="max-width: 1200px;">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold text-gray-800">Dashboard</h1>
      <form action="/logout" method="POST">
        <button type="submit" class="bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition duration-200">
          Sair
        </button>
      </form>
    </div>

    <p class="text-lg text-gray-600 mb-8">Bem-vindo, <%= userName %>!</p>

    <!-- Financial Summary -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white p-8 rounded-xl shadow-md border border-gray-100">
        <h2 class="text-lg font-semibold text-gray-700 mb-2">Total de Entradas</h2>
        <p class="text-3xl font-bold text-emerald-600">R$ <%= totalIncome %></p>
      </div>
      <div class="bg-white p-8 rounded-xl shadow-md border border-gray-100">
        <h2 class="text-lg font-semibold text-gray-700 mb-2">Total de Despesas</h2>
        <p class="text-3xl font-bold text-rose-500">R$ <%= totalExpenses %></p>
      </div>
      <div class="bg-white p-8 rounded-xl shadow-md border border-gray-100">
        <h2 class="text-lg font-semibold text-gray-700 mb-2">Saldo</h2>
        <p class="text-3xl font-bold <%= balance >= 0 ? 'text-slate-700' : 'text-rose-500' %>">R$ <%= balance %></p>
      </div>
    </div>

    <!-- Transactions List -->
    <div class="bg-white p-8 rounded-xl shadow-md border border-gray-100">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-gray-800">Transações</h2>
        <a href="/transactions/add" class="bg-slate-600 hover:bg-slate-700 text-white font-medium py-2 px-4 rounded-lg transition duration-200">
          + Adicionar Transação
        </a>
      </div>
      <% if (transactions.length === 0) { %>
        <p class="text-gray-500 text-center py-8">Nenhuma transação encontrada.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full table-auto">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Data</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Descrição</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Valor</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% transactions.forEach(transaction => { %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= new Date(transaction.date).toLocaleDateString('pt-BR') %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= transaction.description %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm">
                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-medium rounded-full <%= transaction.type === 'income' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                      <%= transaction.type === 'income' ? 'Entrada' : 'Despesa' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium">
                    R$ <%= parseFloat(transaction.amount).toFixed(2) %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <a href="/transactions/edit/<%= transaction.id %>" class="text-slate-600 hover:text-slate-800 mr-4 transition duration-200">Editar</a>
                    <form action="/transactions/delete/<%= transaction.id %>" method="POST" class="inline" onsubmit="return confirm('Tem certeza que deseja excluir esta transação?')">
                      <button type="submit" class="text-rose-600 hover:text-rose-800 transition duration-200">Excluir</button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>