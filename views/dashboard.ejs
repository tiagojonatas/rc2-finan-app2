<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Visao Geral - RC2 Finance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            'sans': ['Inter', 'system-ui', 'sans-serif'],
          },
          colors: {
            'custom-bg': '#0F172A',
            'brand-purple': '#00C9A7',
            'brand-cyan-light': '#3A86FF',
            'brand-cyan-dark': '#009e83',
            'brand-cyan-50': '#ecfeff',
            'brand-cyan-100': '#cffafe',
            'brand-cyan-200': '#a5f3fc',
          }
        }
      }
    }
  </script>
  <style>
    body {
      background: #f9fafb;
      font-family: 'Inter', system-ui, sans-serif;
      min-height: 100vh;
      color: #111827;
    }
    .glass-card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      box-shadow: 0 1px 2px 0 rgba(15, 23, 42, 0.06);
      transition: box-shadow 150ms ease;
    }
    .glass-card:hover {
      box-shadow: 0 8px 20px -14px rgba(15, 23, 42, 0.30);
    }
    .soft-shadow {
      box-shadow: 0 1px 2px 0 rgba(15, 23, 42, 0.06);
    }
    .header-glass-btn {
      background: #ffffff;
      border: 1px solid #e5e7eb;
    }
    .toast-enter {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
    .toast-show {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    .tx-highlight {
      animation: txPulse 1.1s ease-out;
    }
    @keyframes txPulse {
      0% { background-color: rgba(0, 201, 167, 0.18); }
      100% { background-color: transparent; }
    }
  </style>
</head>
<body class="bg-gray-50 font-sans text-slate-900">
  <div class="container mx-auto px-4 sm:px-6 py-6 sm:py-8 max-w-5xl relative pb-28 space-y-8">
    <div class="flex items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <img src="/brand/rc2-finance-horizontal.svg" alt="RC2 Finance" class="h-9 sm:h-10 w-auto" />
        <p class="text-xs text-slate-500 hidden sm:block">by RC2 Tecnologia</p>
      </div>
      <div class="flex items-center gap-2 sm:gap-3">
        <a href="/credit-cards" class="header-glass-btn min-h-[44px] hover:bg-gray-100 text-brand-purple font-medium py-2 px-3 sm:px-4 rounded-xl transition-all duration-200 hover:scale-105 inline-flex items-center justify-center">
          Cartoes
        </a>
        <form action="/logout" method="POST">
          <button type="submit" class="header-glass-btn min-h-[44px] hover:bg-gray-100 text-gray-700 hover:text-brand-purple font-medium py-2 px-3 sm:px-4 rounded-xl transition-all duration-200 hover:scale-105">
            Sair
          </button>
        </form>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
      <div>
        <h1 class="text-2xl sm:text-3xl font-semibold text-slate-900">Visao Geral</h1>
        <p id="currentMonth" class="text-base sm:text-lg text-brand-purple mt-1.5 sm:mt-2 font-medium"></p>
      </div>
      <div class="w-full sm:w-auto flex flex-col sm:flex-row sm:flex-wrap items-stretch sm:items-center sm:justify-end gap-2 sm:gap-3">
        <form id="monthFilterForm" action="/dashboard" method="GET" class="header-glass-btn rounded-xl px-3 py-2 min-h-[44px] flex items-center gap-2">
          <label for="monthFilter" class="text-xs font-semibold text-gray-600 uppercase tracking-wide">Periodo</label>
          <select id="monthFilter" name="month" class="bg-transparent text-sm font-semibold text-brand-purple focus:outline-none w-full sm:w-auto">
            <% const safeMonthOptions = Array.isArray(monthOptions) ? monthOptions : []; %>
            <% safeMonthOptions.forEach((monthKey) => { %>
              <% const [year, month] = monthKey.split('-').map(Number); %>
              <% const monthLabel = new Date(year, month - 1, 1).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }); %>
              <option value="<%= monthKey %>" <%= monthKey === selectedMonth ? 'selected' : '' %>><%= monthLabel %></option>
            <% }); %>
          </select>
        </form>
        <a href="/reports" class="header-glass-btn min-h-[44px] hover:bg-gray-100 text-brand-purple font-medium py-2 px-4 rounded-xl transition-all duration-200 hover:scale-105 inline-flex items-center justify-center">
          Relatorios
        </a>
        <a href="/categories" class="header-glass-btn min-h-[44px] hover:bg-gray-100 text-brand-purple font-medium py-2 px-4 rounded-xl transition-all duration-200 hover:scale-105 inline-flex items-center justify-center">
          Categorias
        </a>
        <a href="/fixed-expenses" class="header-glass-btn min-h-[44px] hover:bg-gray-100 text-brand-purple font-medium py-2 px-4 rounded-xl transition-all duration-200 hover:scale-105 inline-flex items-center justify-center">
          Fixas
        </a>
      </div>
    </div>

    <% if (typeof dashboardToast !== 'undefined' && dashboardToast) { %>
      <div id="dashboardToast"
           class="toast-enter transition-all duration-200 mb-6 glass-card soft-shadow rounded-xl border border-emerald-200/80 px-4 py-3">
        <p class="text-sm font-semibold text-emerald-700"><%= dashboardToast %></p>
      </div>
    <% } %>

    <!-- Featured Balance Section -->
    <div class="glass-card rounded-xl border border-gray-200 p-6 sm:p-8 md:p-10 transition-all duration-200 relative overflow-hidden">
      <div class="absolute inset-x-0 top-0 h-10 bg-brand-cyan-50/70 pointer-events-none"></div>
      <div class="text-center relative z-10">
        <p class="text-sm font-medium text-gray-500 mb-3 uppercase tracking-wide">Seu saldo atual</p>
        <h2 class="text-lg font-medium text-gray-600 mb-4">Saldo disponivel</h2>
        <p class="text-3xl sm:text-4xl font-semibold <%= balance >= 0 ? 'text-brand-purple' : 'text-rose-500' %>">
          <%= formatCurrency(balance) %>
        </p>
      </div>
    </div>

    <!-- Monthly Summary -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="glass-card rounded-lg border border-gray-200 p-4">
        <p class="text-xs text-gray-400 mb-1 font-medium uppercase tracking-wide">Receitas</p>
        <p class="text-lg font-semibold text-emerald-600"><%= formatCurrency(totalIncome) %></p>
      </div>
      <div class="glass-card rounded-lg border border-gray-200 p-4">
        <p class="text-xs text-gray-400 mb-1 font-medium uppercase tracking-wide">Gastos</p>
        <p class="text-lg font-semibold text-rose-600"><%= formatCurrency(totalExpenses) %></p>
      </div>
      <div class="glass-card rounded-lg border border-gray-200 p-4 sm:col-span-2 lg:col-span-1">
        <p class="text-xs text-gray-400 mb-1 font-medium uppercase tracking-wide">Despesas fixas</p>
        <p class="text-lg font-semibold text-brand-purple"><%= formatCurrency(totalFixedExpenses) %></p>
      </div>
    </div>

    <!-- Monthly Projection -->
    <% const projection = monthlyProjection || {}; %>
    <div class="glass-card rounded-xl border overflow-hidden <%= projection.isPositive ? 'border-emerald-100' : 'border-rose-100' %>">
      <div class="px-6 py-4 bg-white border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">Previsao de gastos do mes</h2>
      </div>
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-5">
          <div class="rounded-lg border border-gray-200 bg-white p-4">
            <p class="text-xs uppercase tracking-wide text-gray-400 mb-1">Despesas fixas</p>
            <p class="text-lg font-semibold text-gray-900"><%= formatCurrency(projection.fixedExpenses || 0) %></p>
          </div>
          <div class="rounded-lg border border-gray-200 bg-white p-4">
            <p class="text-xs uppercase tracking-wide text-gray-400 mb-1">Media variavel (3m)</p>
            <p class="text-lg font-semibold text-gray-900"><%= formatCurrency(projection.averageVariableExpenses || 0) %></p>
          </div>
          <div class="rounded-lg border border-gray-200 bg-white p-4">
            <p class="text-xs uppercase tracking-wide text-gray-400 mb-1">Estimativa total do mes</p>
            <p class="text-lg font-semibold text-gray-900"><%= formatCurrency(projection.estimatedTotalMonthExpense || 0) %></p>
          </div>
        </div>
        <div class="rounded-lg px-4 py-4 border <%= projection.isPositive ? 'bg-emerald-50 border-emerald-100' : 'bg-rose-50 border-rose-100' %>">
          <p class="text-xs uppercase tracking-wide mb-1 <%= projection.isPositive ? 'text-emerald-700' : 'text-rose-700' %>">Saldo projetado</p>
          <p class="text-3xl font-bold <%= projection.isPositive ? 'text-emerald-700' : 'text-rose-700' %>"><%= formatCurrency(projection.projectedBalance || 0) %></p>
        </div>
      </div>
    </div>


    <!-- Credit Card Financial Summary -->
    <% const summary = (typeof creditCardSummary !== 'undefined' && creditCardSummary) ? creditCardSummary : {}; %>
    <div>
      <div class="glass-card rounded-xl overflow-hidden <%= summary.isRisk ? 'border-rose-200' : 'border-gray-200' %>">
        <div class="px-6 py-4 bg-white border-b border-gray-100">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <h2 class="text-xl font-semibold text-gray-900">Resumo do Cartao</h2>
            <a href="/credit-cards" class="text-sm font-medium <%= summary.isRisk ? 'text-rose-600 hover:text-rose-700' : 'text-brand-purple hover:text-brand-cyan-dark' %>">
              Gerenciar cartoes
            </a>
          </div>
        </div>

        <% if (!summary.hasCards) { %>
          <div class="px-6 py-8 text-center">
            <p class="text-gray-700 mb-4">Voce ainda nao possui cartao cadastrado.</p>
            <a href="/credit-cards/add" class="inline-block bg-brand-purple hover:bg-brand-cyan-dark text-white font-medium py-2 px-5 rounded-lg shadow-sm transition-all duration-200">
              + Adicionar Cartao
            </a>
          </div>
        <% } else { %>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
              <div class="rounded-lg border <%= summary.isRisk ? 'border-rose-200 bg-rose-50/50' : 'border-gray-200 bg-brand-cyan-50/40' %> p-4">
                <p class="text-xs uppercase tracking-wide mb-1 <%= summary.isRisk ? 'text-rose-600' : 'text-brand-purple' %>">Fatura Atual</p>
                <p class="text-2xl font-bold <%= summary.isRisk ? 'text-rose-700' : 'text-gray-900' %>"><%= formatCurrency(summary.currentInvoice) %></p>
              </div>

              <div class="rounded-lg border border-gray-200 bg-white p-4">
                <p class="text-xs uppercase tracking-wide mb-1 text-gray-500">Fechamento</p>
                <p class="text-xl font-bold text-gray-900">
                  <%= summary.nextClosingDate ? formatDate(summary.nextClosingDate) : '-' %>
                </p>
              </div>

              <div class="rounded-lg border border-gray-200 bg-white p-4">
                <p class="text-xs uppercase tracking-wide mb-1 text-gray-500">Vencimento</p>
                <p class="text-xl font-bold text-gray-900">
                  <%= summary.nextDueDate ? formatDate(summary.nextDueDate) : '-' %>
                </p>
              </div>
            </div>

            <div class="rounded-lg border <%= summary.isRisk ? 'border-rose-200 bg-rose-50/40' : 'border-gray-200 bg-brand-cyan-50/20' %> p-4">
              <div class="flex items-center justify-between mb-2">
                <p class="text-sm font-medium <%= summary.isRisk ? 'text-rose-700' : 'text-gray-700' %>">Limite Utilizado</p>
                <p class="text-sm font-bold <%= summary.isRisk ? 'text-rose-700' : 'text-brand-purple' %>"><%= Math.round(summary.usedPercent || 0) %>%</p>
              </div>

              <div class="w-full h-3 rounded-full bg-gray-200 overflow-hidden">
                <div
                  class="h-full rounded-full transition-all duration-500 <%= summary.isRisk ? 'bg-gradient-to-r from-rose-500 to-red-600' : 'bg-[#00C9A7]' %>"
                  style="width: <%= Math.max(0, Math.min(100, summary.progressPercent || 0)) %>%;">
                </div>
              </div>

              <div class="flex items-center justify-between mt-3 text-xs">
                <span class="<%= summary.isRisk ? 'text-rose-600' : 'text-gray-500' %>">
                  Limite total: <strong><%= formatCurrency(summary.totalLimit) %></strong>
                </span>
                <% if (summary.isRisk) { %>
                  <span class="font-semibold text-rose-700">Risco de estouro</span>
                <% } else { %>
                  <span class="font-semibold text-emerald-600">Dentro do planejado</span>
                <% } %>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Transactions Section -->
    <div>
      <h2 class="text-2xl font-semibold text-gray-900 mb-6 flex items-center">
        <span class="w-1 h-8 bg-brand-purple rounded-full mr-3"></span>
        Transacoes
      </h2>

      <% const safeTransactionGroups = Array.isArray(transactionGroups) ? transactionGroups : []; %>

      <% if (safeTransactionGroups.length === 0) { %>
        <div class="glass-card text-center py-16 rounded-xl border border-gray-200">
          <h3 class="text-lg font-medium text-gray-900 mb-2">Nenhuma transacao</h3>
          <p class="text-brand-purple">Adicione sua primeira transacao.</p>
        </div>
      <% } else { %>
        <% safeTransactionGroups.forEach((group, groupIndex) => { %>
          <div class="<%= groupIndex < safeTransactionGroups.length - 1 ? 'mb-6' : '' %>">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-2 px-4 py-3 rounded-xl bg-gray-50 border border-gray-200">
              <h3 class="text-sm sm:text-base font-semibold text-gray-900 tracking-wide">
                <%= group && group.dateLabel ? group.dateLabel : 'Data nao definida' %>
              </h3>
              <div class="flex items-center gap-2 text-xs">
                <% if (group && group.totalIncome && group.totalIncome > 0) { %>
                  <span class="px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 font-semibold">
                    + <%= formatCurrency(group.totalIncome) %>
                  </span>
                <% } %>
                <% if (group && group.totalExpenses && group.totalExpenses > 0) { %>
                  <span class="px-2.5 py-1 rounded-full bg-rose-50 text-rose-700 font-semibold">
                    - <%= formatCurrency(group.totalExpenses) %>
                  </span>
                <% } %>
              </div>
            </div>

            <div class="glass-card rounded-xl border border-gray-200 overflow-hidden">
              <% if (group && group.transactions && Array.isArray(group.transactions) && group.transactions.length > 0) { %>
                <% group.transactions.forEach((transaction, index) => { %>
                  <div data-transaction-id="<%= transaction && transaction.id ? transaction.id : '' %>"
                       class="group px-4 sm:px-5 py-4 sm:py-5 transition-all duration-200 hover:bg-gray-50 <%= index < group.transactions.length - 1 ? 'border-b border-gray-100' : '' %>">
                    <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
                      <div class="flex-shrink-0 w-10 h-10 sm:w-11 sm:h-11 rounded-full flex items-center justify-center <%= transaction && transaction.type === 'income' ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600' %>">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
                          <% if (transaction && transaction.type === 'income') { %>
                            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v7.586l2.293-2.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 11.586V4a1 1 0 011-1z" clip-rule="evenodd" />
                          <% } else { %>
                            <path fill-rule="evenodd" d="M10 17a1 1 0 01-1-1V8.414L6.707 10.707a1 1 0 11-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 11-1.414 1.414L11 8.414V16a1 1 0 01-1 1z" clip-rule="evenodd" />
                          <% } %>
                        </svg>
                      </div>

                      <div class="flex-1 min-w-0 order-1 sm:order-none">
                        <div class="flex items-start justify-between gap-3 sm:gap-2">
                          <p class="text-sm sm:text-base font-semibold text-gray-900 leading-snug">
                            <%= transaction && transaction.description ? transaction.description : 'Sem descricao' %>
                          </p>
                          <p class="text-base sm:text-xl font-bold whitespace-nowrap <%= transaction && transaction.type === 'income' ? 'text-emerald-600' : 'text-rose-600' %>">
                            <%= transaction && transaction.type === 'income' ? '+' : '-' %><%= formatCurrency(Math.abs(transaction && transaction.amount ? transaction.amount : 0)) %>
                          </p>
                        </div>
                        <div class="flex flex-wrap items-center gap-2 mt-2">
                          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold <%= transaction && transaction.type === 'income' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                            <%= transaction && transaction.type === 'income' ? 'Entrada' : 'Saida' %>
                          </span>
                          <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[11px] font-semibold text-gray-700 bg-white border border-gray-200">
                            <span class="w-2 h-2 rounded-full" style="background-color: <%= transaction && transaction.category_color ? transaction.category_color : '#00C9A7' %>;"></span>
                            <%= transaction && transaction.category_name ? transaction.category_name : 'Sem categoria' %>
                          </span>
                          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold border <%= transaction && transaction.payment_method === 'credit' ? 'bg-sky-50 text-sky-700 border-sky-200' : transaction && transaction.payment_method === 'debit' ? 'bg-sky-50 text-sky-700 border-sky-200' : 'bg-amber-50 text-amber-700 border-amber-200' %>">
                            <%= transaction && transaction.payment_method === 'credit' ? 'Credito' : transaction && transaction.payment_method === 'debit' ? 'Debito' : 'Dinheiro' %>
                          </span>
                          <% if (transaction && Number(transaction.is_recurring || 0) === 1) { %>
                            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-semibold bg-brand-cyan-50 text-brand-purple border border-brand-cyan-200">
                              Fixo
                            </span>
                          <% } %>
                        </div>
                        <p class="text-xs text-gray-400 mt-2">
                          <%= transaction && transaction.date ? formatDate(transaction.date) : '' %>
                        </p>
                      </div>

                      <div class="order-2 sm:order-none">
                        <div class="mt-1 flex items-center justify-end sm:justify-start gap-2 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                          <a href="/transactions/edit/<%= transaction && transaction.id ? transaction.id : '' %>"
                             class="text-xs px-3 py-2 min-h-[44px] rounded-md bg-gray-100 hover:bg-gray-200 text-gray-700 inline-flex items-center">
                            Editar
                          </a>
                          <form action="/transactions/delete/<%= transaction && transaction.id ? transaction.id : '' %>" method="POST" class="inline"
                                onsubmit="return confirm('Tem certeza que deseja excluir esta transacao?')">
                            <button type="submit"
                                    class="text-xs px-3 py-2 min-h-[44px] rounded-md bg-rose-50 hover:bg-rose-100 text-rose-700 inline-flex items-center">
                              Excluir
                            </button>
                          </form>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }); %>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

    <!-- Floating Action Menu -->
    <div class="fixed bottom-5 right-4 sm:bottom-6 sm:right-6 z-50 flex flex-col items-end gap-3">
      <div id="actionMenu"
           class="origin-bottom-right opacity-0 scale-95 pointer-events-none transition-all duration-200 ease-out flex flex-col gap-2">
        <a href="/transactions/add?type=income"
           class="glass-card min-h-[44px] border border-gray-200 text-gray-700 rounded-lg px-4 py-2 text-sm font-semibold hover:bg-gray-50 transition-all duration-200 inline-flex items-center">
          Nova receita
        </a>
        <a href="/transactions/add?type=expense"
           class="glass-card min-h-[44px] border border-gray-200 text-gray-700 rounded-lg px-4 py-2 text-sm font-semibold hover:bg-gray-50 transition-all duration-200 inline-flex items-center">
          Nova despesa
        </a>
        <button id="openCardPurchaseModal"
           type="button"
           class="glass-card min-h-[44px] border border-gray-200 text-gray-700 rounded-lg px-4 py-2 text-sm font-semibold hover:bg-gray-50 transition-all duration-200 text-left">
          Nova compra no cartao
        </button>
      </div>

      <button id="actionFab"
              type="button"
              aria-label="Abrir menu de acoes"
              class="w-14 h-14 sm:w-16 sm:h-16 min-h-[44px] bg-[#00C9A7] hover:bg-[#009e83] rounded-full shadow-lg flex items-center justify-center text-white text-3xl font-bold transition-all duration-200 hover:scale-105">
        +
      </button>
    </div>

    <% const safeDashboardCards = Array.isArray(dashboardCards) ? dashboardCards : []; %>
    <div id="cardPurchaseModal" class="fixed inset-0 z-[60] hidden items-center justify-center p-4">
      <div id="cardPurchaseBackdrop" class="absolute inset-0 bg-black/30 opacity-0 transition-opacity duration-200"></div>
      <div id="cardPurchasePanel" class="glass-card relative w-full max-w-md rounded-xl border border-gray-200 p-6 opacity-0 scale-95 transition-all duration-200">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Nova compra no cartao</h3>
          <button id="closeCardPurchaseModal" type="button" class="text-gray-500 hover:text-gray-700 text-xl leading-none">&times;</button>
        </div>
        <% if (safeDashboardCards.length === 0) { %>
          <p class="text-sm text-gray-600 mb-4">Voce ainda nao tem cartoes cadastrados.</p>
          <a href="/credit-cards/add" class="inline-block bg-brand-purple hover:bg-brand-cyan-dark text-white font-medium py-2 px-4 rounded-lg shadow-sm transition-all duration-200">
            Adicionar cartao
          </a>
        <% } else { %>
          <div class="flex flex-col gap-2 max-h-64 overflow-auto pr-1">
            <% safeDashboardCards.forEach((card) => { %>
              <a href="/credit-cards/<%= card.id %>/add-transaction"
                 class="w-full rounded-xl border border-gray-200 bg-white hover:bg-gray-50 text-gray-800 px-4 py-3 text-sm font-semibold transition-all duration-200">
                <%= card.name %>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <script>
      // Mostrar mГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬В ГѓВўГўвЂљВ¬ГўвЂћВўГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г‚В ГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓВўГўв‚¬ЕѕГ‚ВўГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓвЂ¦Г‚ВЎГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г…ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚ВЄs atual no dashboard
      document.addEventListener('DOMContentLoaded', function() {
        const currentMonthElement = document.getElementById('currentMonth');
        const selectedMonthLabel = <%- JSON.stringify(typeof selectedMonthLabel !== 'undefined' ? selectedMonthLabel : '') %>;
        if (currentMonthElement) {
          currentMonthElement.textContent = selectedMonthLabel || '';
        }

        const monthFilter = document.getElementById('monthFilter');
        const monthFilterForm = document.getElementById('monthFilterForm');
        if (monthFilter && monthFilterForm) {
          monthFilter.addEventListener('change', function() {
            monthFilterForm.submit();
          });
        }

        const toastEl = document.getElementById('dashboardToast');
        const highlightedTxId = <%- JSON.stringify(typeof highlightedTransactionId !== 'undefined' ? highlightedTransactionId : null) %>;

        if (toastEl) {
          requestAnimationFrame(function() {
            toastEl.classList.add('toast-show');
          });

          setTimeout(function() {
            toastEl.classList.remove('toast-show');
            toastEl.classList.add('toast-enter');
          }, 2600);

          setTimeout(function() {
            if (toastEl && toastEl.parentNode) {
              toastEl.parentNode.removeChild(toastEl);
            }
          }, 3000);
        }

        if (highlightedTxId) {
          const txEl = document.querySelector(`[data-transaction-id=\"${highlightedTxId}\"]`);
          if (txEl) {
            txEl.classList.add('tx-highlight');
            txEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }

        if (window.history && window.history.replaceState) {
          const cleanUrl = new URL(window.location.href);
          cleanUrl.searchParams.delete('toast');
          cleanUrl.searchParams.delete('tx');
          window.history.replaceState({}, '', cleanUrl.pathname + cleanUrl.search + cleanUrl.hash);
        }

        const actionFab = document.getElementById('actionFab');
        const actionMenu = document.getElementById('actionMenu');
        const openCardPurchaseModalBtn = document.getElementById('openCardPurchaseModal');
        const cardPurchaseModal = document.getElementById('cardPurchaseModal');
        const cardPurchaseBackdrop = document.getElementById('cardPurchaseBackdrop');
        const cardPurchasePanel = document.getElementById('cardPurchasePanel');
        const closeCardPurchaseModalBtn = document.getElementById('closeCardPurchaseModal');
        let isActionMenuOpen = false;
        let isCardPurchaseModalOpen = false;

        function setActionMenuState(open) {
          isActionMenuOpen = open;
          if (!actionFab || !actionMenu) return;

          if (open) {
            actionMenu.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
            actionMenu.classList.add('opacity-100', 'scale-100');
            actionFab.classList.add('rotate-45');
          } else {
            actionMenu.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
            actionMenu.classList.remove('opacity-100', 'scale-100');
            actionFab.classList.remove('rotate-45');
          }
        }

        function setCardPurchaseModalState(open) {
          isCardPurchaseModalOpen = open;
          if (!cardPurchaseModal || !cardPurchaseBackdrop || !cardPurchasePanel) return;

          if (open) {
            cardPurchaseModal.classList.remove('hidden');
            cardPurchaseModal.classList.add('flex');
            requestAnimationFrame(function() {
              cardPurchaseBackdrop.classList.remove('opacity-0');
              cardPurchaseBackdrop.classList.add('opacity-100');
              cardPurchasePanel.classList.remove('opacity-0', 'scale-95');
              cardPurchasePanel.classList.add('opacity-100', 'scale-100');
            });
          } else {
            cardPurchaseBackdrop.classList.add('opacity-0');
            cardPurchaseBackdrop.classList.remove('opacity-100');
            cardPurchasePanel.classList.add('opacity-0', 'scale-95');
            cardPurchasePanel.classList.remove('opacity-100', 'scale-100');
            setTimeout(function() {
              if (!isCardPurchaseModalOpen) {
                cardPurchaseModal.classList.add('hidden');
                cardPurchaseModal.classList.remove('flex');
              }
            }, 200);
          }
        }

        if (actionFab && actionMenu) {
          actionFab.addEventListener('click', function() {
            setActionMenuState(!isActionMenuOpen);
          });

          if (openCardPurchaseModalBtn) {
            openCardPurchaseModalBtn.addEventListener('click', function() {
              setActionMenuState(false);
              setCardPurchaseModalState(true);
            });
          }

          if (closeCardPurchaseModalBtn) {
            closeCardPurchaseModalBtn.addEventListener('click', function() {
              setCardPurchaseModalState(false);
            });
          }

          if (cardPurchaseBackdrop) {
            cardPurchaseBackdrop.addEventListener('click', function() {
              setCardPurchaseModalState(false);
            });
          }

          document.addEventListener('click', function(event) {
            const clickedInsideMenu = actionMenu.contains(event.target);
            const clickedFab = actionFab.contains(event.target);
            if (!clickedInsideMenu && !clickedFab) {
              setActionMenuState(false);
            }
          });

          document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
              setActionMenuState(false);
              setCardPurchaseModalState(false);
            }
          });
        }
      });
    </script>
  </div></body>
</html>
















