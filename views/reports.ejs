<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Relatorios - Sistema Financeiro</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
          colors: {
            'brand-purple': '#8A05BE',
            'brand-purple-dark': '#6A047E',
            'brand-purple-50': '#F8F0FF',
            'brand-purple-100': '#E9D5FF'
          }
        }
      }
    }
  </script>
</head>
<body class="bg-slate-100 font-sans text-gray-900">
  <% const safeMonthOptions = Array.isArray(monthOptions) ? monthOptions : []; %>
  <% const safeExpenseCategoryReport = Array.isArray(expenseCategoryReport) ? expenseCategoryReport : []; %>
  <% const safeMonthlyBalanceData = Array.isArray(monthlyBalanceData) ? monthlyBalanceData : []; %>

  <div class="container mx-auto px-6 py-8 max-w-6xl">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Relatorios</h1>
        <p class="text-sm text-gray-500 mt-1"><%= selectedMonthLabel || '' %></p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <form id="monthFilterForm" action="/reports" method="GET" class="bg-white border border-brand-purple-100 rounded-xl px-3 py-2 flex items-center gap-2">
          <label for="monthFilter" class="text-xs font-semibold text-gray-600 uppercase tracking-wide">Periodo</label>
          <select id="monthFilter" name="month" class="bg-transparent text-sm font-semibold text-brand-purple focus:outline-none">
            <% safeMonthOptions.forEach((monthKey) => { %>
              <% const [year, month] = monthKey.split('-').map(Number); %>
              <% const monthLabel = new Date(year, month - 1, 1).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }); %>
              <option value="<%= monthKey %>" <%= monthKey === selectedMonth ? 'selected' : '' %>><%= monthLabel %></option>
            <% }); %>
          </select>
        </form>
        <a href="/dashboard" class="bg-white border border-gray-300 text-gray-700 py-2 px-4 rounded-xl hover:bg-gray-50">Dashboard</a>
      </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-8">
      <div class="bg-white rounded-2xl border border-brand-purple-100 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">Gastos por Categoria</h2>
          <span class="text-xs font-medium text-brand-purple bg-brand-purple-50 px-2 py-1 rounded-full">Pizza</span>
        </div>
        <% if (safeExpenseCategoryReport.length === 0) { %>
          <div class="h-72 flex items-center justify-center text-gray-500 text-sm">Sem despesas no periodo selecionado</div>
        <% } else { %>
          <div class="h-72">
            <canvas id="expensePieChart"></canvas>
          </div>
        <% } %>
      </div>

      <div class="bg-white rounded-2xl border border-brand-purple-100 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">Evolucao de Saldo</h2>
          <span class="text-xs font-medium text-brand-purple bg-brand-purple-50 px-2 py-1 rounded-full">Linha</span>
        </div>
        <% if (safeMonthlyBalanceData.length === 0) { %>
          <div class="h-72 flex items-center justify-center text-gray-500 text-sm">Sem historico suficiente</div>
        <% } else { %>
          <div class="h-72">
            <canvas id="balanceLineChart"></canvas>
          </div>
        <% } %>
      </div>
    </div>

    <div class="bg-white rounded-2xl border border-brand-purple-100 shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900">Ranking de Categorias</h2>
        <span class="text-sm font-semibold text-gray-600">Total: <%= formatCurrency(totalExpenses) %></span>
      </div>
      <% if (safeExpenseCategoryReport.length === 0) { %>
        <p class="text-sm text-gray-500">Nenhum gasto no periodo para montar ranking.</p>
      <% } else { %>
        <div class="space-y-2">
          <% safeExpenseCategoryReport.forEach((item, index) => { %>
            <div class="flex items-center justify-between rounded-xl border border-gray-100 bg-slate-50 px-4 py-3">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-gray-800 truncate flex items-center gap-2">
                  <span class="inline-block w-2.5 h-2.5 rounded-full" style="background-color: <%= item.color %>;"></span>
                  <span><%= index + 1 %>. <%= item.name %></span>
                </p>
                <p class="text-xs text-gray-500"><%= item.percentage.toFixed(1) %>% do total</p>
              </div>
              <p class="text-sm font-bold text-gray-900 ml-3"><%= formatCurrency(item.total) %></p>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const monthFilter = document.getElementById('monthFilter');
      const monthFilterForm = document.getElementById('monthFilterForm');
      if (monthFilter && monthFilterForm) {
        monthFilter.addEventListener('change', function() {
          monthFilterForm.submit();
        });
      }

      const expenseCategoryReportServer = <%- JSON.stringify(safeExpenseCategoryReport) %>;
      const monthlyBalanceDataServer = <%- JSON.stringify(safeMonthlyBalanceData) %>;

      const pieCanvas = document.getElementById('expensePieChart');
      if (pieCanvas && expenseCategoryReportServer.length > 0 && typeof Chart !== 'undefined') {
        new Chart(pieCanvas, {
          type: 'pie',
          data: {
            labels: expenseCategoryReportServer.map(function(item) { return item.name; }),
            datasets: [{
              data: expenseCategoryReportServer.map(function(item) { return Number(item.total) || 0; }),
              backgroundColor: expenseCategoryReportServer.map(function(item) { return item.color || '#8A05BE'; }),
              borderColor: '#ffffff',
              borderWidth: 2,
              hoverOffset: 8
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'bottom',
                labels: { usePointStyle: true, boxWidth: 8, padding: 16 }
              },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    const idx = context.dataIndex;
                    const item = expenseCategoryReportServer[idx];
                    const value = Number(context.parsed || 0);
                    const percentage = item ? Number(item.percentage || 0).toFixed(1) : '0.0';
                    return `${new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value)} (${percentage}%)`;
                  }
                }
              }
            }
          }
        });
      }

      const lineCanvas = document.getElementById('balanceLineChart');
      if (lineCanvas && monthlyBalanceDataServer.length > 0 && typeof Chart !== 'undefined') {
        new Chart(lineCanvas, {
          type: 'line',
          data: {
            labels: monthlyBalanceDataServer.map(function(item) { return item.label; }),
            datasets: [{
              label: 'Saldo',
              data: monthlyBalanceDataServer.map(function(item) { return Number(item.balance) || 0; }),
              borderColor: '#8A05BE',
              backgroundColor: 'rgba(138, 5, 190, 0.12)',
              pointBackgroundColor: monthlyBalanceDataServer.map(function(item) { return (Number(item.balance) || 0) < 0 ? '#ef4444' : '#8A05BE'; }),
              pointBorderColor: '#ffffff',
              pointBorderWidth: 2,
              pointRadius: 4,
              fill: true,
              tension: 0.35
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              y: {
                grid: { color: 'rgba(148, 163, 184, 0.18)' },
                ticks: {
                  callback: function(value) {
                    return new Intl.NumberFormat('pt-BR', {
                      style: 'currency',
                      currency: 'BRL',
                      maximumFractionDigits: 0
                    }).format(value);
                  }
                }
              },
              x: { grid: { display: false } }
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    return new Intl.NumberFormat('pt-BR', {
                      style: 'currency',
                      currency: 'BRL'
                    }).format(context.parsed.y || 0);
                  }
                }
              }
            }
          }
        });
      }
    });
  </script>
</body>
</html>
